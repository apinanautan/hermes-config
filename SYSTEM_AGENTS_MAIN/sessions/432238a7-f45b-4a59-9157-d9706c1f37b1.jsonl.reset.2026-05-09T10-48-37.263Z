etail.`]\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\treturn orderedIds.filter((id, index) => orderedIds.indexOf(id) === index).map((id) => {\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\tconst nextAgentsList = listAgentEntries(cfg).filter((entry) => normalizeAgentId(entry.id) !== id);\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\tconst filteredBindings = bindings.filter((binding) => normalizeAgentId(binding.agentId) !== id);\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\tconst filteredAllow = allow.filter((entry) => entry !== id);\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\t\t\tallow: filteredAllow.length > 0 ? filteredAllow : void 0\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\t\t\tbindings: filteredBindings.length > 0 ? filteredBindings : void 0,\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\t\tremovedBindings: bindings.length - filteredBindings.length,\n/home/apinan/.hermes/node/lib/node_modules/openclaw/dist/agents.config-C35QDL1Z.js:\t\tremovedAllow: allow.length - filteredAllow.length","cwd":"/home/apinan/.openclaw/workspace"},"isError":false,"timestamp":1778278791704}}
