{"type":"message","id":"8e93b69d","parentId":"fb42a12f","timestamp":"2026-05-09T09:37:43.655Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to understand the full picture. Let me read the hook handler and the HOOK.yaml to understand the bridge flow.\n","thinkingSignature":"c6084e4202d0bb04f51a2da6c408c8bca96c31792dcc37d8ae1d9c4a3052c983"},{"type":"toolCall","id":"call_function_b211qsuaknmn_1","name":"exec","arguments":{"command":"cat ~/.hermes/hooks/minimax-bridge/HOOK.yaml && echo \"---\" && cat ~/.hermes/hooks/minimax-bridge/handler.py","timeout":10}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":252,"output":93,"cacheRead":110400,"cacheWrite":0,"totalTokens":110745,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778319456881,"responseId":"064e336345cdba7edd4ed3191d23eea0"}}
{"type":"message","id":"37e91b32","parentId":"8e93b69d","timestamp":"2026-05-09T09:37:43.703Z","message":{"role":"toolResult","toolCallId":"call_function_b211qsuaknmn_1","toolName":"exec","content":[{"type":"text","text":"name: minimax-bridge\ndescription: \"Preprocessor hook: ทุกข้อความจากเจ้านาย ต้องผ่าน universal_bridge.py ก่อน agent:start\"\nevents:\n  - agent:start---\n\"\"\"\nMinimax Bridge Preprocessor Hook\n\nFires on: agent:start\nPurpose:  ทุกข้อความจากเจ้านาย ต้องผ่าน universal_bridge.py ก่อน\n          ถ้า bridge สำเร็จ → inject ผลลัพธ์ลง context แล้ว agent จบทันที\n          ถ้า bridge ล้ม → ปล่อย agent ประมวลผลตามปกติ\n\nContext modified:\n  - _bridge_result: str   — ผลลัพธ์จาก bridge (ถ้าสำเร็จ)\n  - _bridge_done: bool   — True = บอก agent ว่าจบแล้ว ไม่ต้องทำอะไร\n\"\"\"\n\nimport subprocess\nimport uuid\nimport os\nimport tempfile\n\nSCRIPT_PATH = os.path.expanduser(\"~/.hermes/scripts/universal_bridge.py\")\nALLOWED_USER = \"robberzaz\"  # Telegram username ของเจ้านาย\n\n\ndef handle(event_type: str, context: dict) -> None:\n    \"\"\"Run on agent:start. Pipe message through bridge, inject result or pass through.\"\"\"\n    if event_type != \"agent:start\":\n        return\n\n    message: str = context.get(\"message\", \"\") or \"\"\n    platform: str = context.get(\"platform\", \"\") or \"\"\n\n    # ข้ามถ้าเป็น internal/system message\n    if message.startswith(\"_\") or message.startswith(\"/\"):\n        return\n\n    # ข้ามถ้าไม่มี script\n    if not os.path.exists(SCRIPT_PATH):\n        return\n\n    # สร้าง temp file สำหรับ output\n    rid = uuid.uuid4().hex[:8]\n    tmp_out = f\"/tmp/hermes_bridge_{rid}.txt\"\n\n    try:\n        # รัน bridge script\n        cmd = [\"python\", SCRIPT_PATH, message]\n        proc = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=120,\n            cwd=os.path.dirname(SCRIPT_PATH),\n        )\n\n        # ถ้าสำเร็จ (exit 0) → inject ผลลัพธ์\n        if proc.returncode == 0:\n            result = proc.stdout.strip()\n            # อ่าน full result จาก stdout\n            if result:\n                context[\"_bridge_result\"] = result\n                context[\"_bridge_done\"] = True\n        # ถ้าไม่สำเร็จ → ปล่อย agent ทำตามปกติ (ไม่ต้องทำอะไร)\n\n    except subprocess.TimeoutExpired:\n        context[\"_bridge_timeout\"] = True\n    except Exception as e:\n        context[\"_bridge_error\"] = str(e)\n    finally:\n        # cleanup temp file\n        if os.path.exists(tmp_out):\n            try:\n                os.remove(tmp_out)\n            except Exception:\n                pass"}],"details":{"status":"completed","exitCode":0,"durationMs":32,"aggregated":"name: minimax-bridge\ndescription: \"Preprocessor hook: ทุกข้อความจากเจ้านาย ต้องผ่าน universal_bridge.py ก่อน agent:start\"\nevents:\n  - agent:start---\n\"\"\"\nMinimax Bridge Preprocessor Hook\n\nFires on: agent:start\nPurpose:  ทุกข้อความจากเจ้านาย ต้องผ่าน universal_bridge.py ก่อน\n          ถ้า bridge สำเร็จ → inject ผลลัพธ์ลง context แล้ว agent จบทันที\n          ถ้า bridge ล้ม → ปล่อย agent ประมวลผลตามปกติ\n\nContext modified:\n  - _bridge_result: str   — ผลลัพธ์จาก bridge (ถ้าสำเร็จ)\n  - _bridge_done: bool   — True = บอก agent ว่าจบแล้ว ไม่ต้องทำอะไร\n\"\"\"\n\nimport subprocess\nimport uuid\nimport os\nimport tempfile\n\nSCRIPT_PATH = os.path.expanduser(\"~/.hermes/scripts/universal_bridge.py\")\nALLOWED_USER = \"robberzaz\"  # Telegram username ของเจ้านาย\n\n\ndef handle(event_type: str, context: dict) -> None:\n    \"\"\"Run on agent:start. Pipe message through bridge, inject result or pass through.\"\"\"\n    if event_type != \"agent:start\":\n        return\n\n    message: str = context.get(\"message\", \"\") or \"\"\n    platform: str = context.get(\"platform\", \"\") or \"\"\n\n    # ข้ามถ้าเป็น internal/system message\n    if message.startswith(\"_\") or message.startswith(\"/\"):\n        return\n\n    # ข้ามถ้าไม่มี script\n    if not os.path.exists(SCRIPT_PATH):\n        return\n\n    # สร้าง temp file สำหรับ output\n    rid = uuid.uuid4().hex[:8]\n    tmp_out = f\"/tmp/hermes_bridge_{rid}.txt\"\n\n    try:\n        # รัน bridge script\n        cmd = [\"python\", SCRIPT_PATH, message]\n        proc = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=120,\n            cwd=os.path.dirname(SCRIPT_PATH),\n        )\n\n        # ถ้าสำเร็จ (exit 0) → inject ผลลัพธ์\n        if proc.returncode == 0:\n            result = proc.stdout.strip()\n            # อ่าน full result จาก stdout\n            if result:\n                context[\"_bridge_result\"] = result\n                context[\"_bridge_done\"] = True\n        # ถ้าไม่สำเร็จ → ปล่อย agent ทำตามปกติ (ไม่ต้องทำอะไร)\n\n    except subprocess.TimeoutExpired:\n        context[\"_bridge_timeout\"] = True\n    except Exception as e:\n        context[\"_bridge_error\"] = str(e)\n    finally:\n        # cleanup temp file\n        if os.path.exists(tmp_out):\n            try:\n                os.remove(tmp_out)\n            except Exception:\n                pass","cwd":"/home/apinan/.openclaw/workspace"},"isError":false,"timestamp":1778319463703}}
