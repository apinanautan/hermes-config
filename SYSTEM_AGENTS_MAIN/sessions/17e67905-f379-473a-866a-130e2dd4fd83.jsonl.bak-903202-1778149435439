nt(\"-n\", \"--lines\", type=int, default=50, help=\"จำนวนบรรทัด (default: 50)\")\n    log_parser.add_argument(\"-f\", \"--follow\", action=\"store_true\", help=\"Follow log realtime\")\n\n    args = parser.parse_args()\n\n    if args.action == \"start\":\n        do_start()\n    elif args.action == \"stop\":\n        do_stop()\n    elif args.action == \"restart\":\n        do_restart()\n    elif args.action == \"status\":\n        do_status()\n    elif args.action == \"logs\":\n        do_logs(args)\n    else:\n        parser.print_help()\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"ollama-pay","model":"kimi-k2.6:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778147359247,"responseId":"chatcmpl-1778147367514"}}
