\n\"):\n        parts = line.strip().split()\n        if len(parts) >= 5:\n            try:\n                pids.append(parts[-1])\n            except ValueError:\n                pass\n    return list(set(pids))\n\ndef kill_pids(pids):\n    \"\"\"Kill PID บน Windows\"\"\"\n    killed = []\n    for pid in pids:\n        stdout, stderr, rc = run_cmd([\"/mnt/c/Windows/System32/taskkill.exe\", \"/F\", \"/PID\", pid], shell=False)\n        if rc == 0:\n            killed.append(pid)\n    return killed\n\ndef is_running():\n    \"\"\"เช็คว่า ComfyUI รันอยู่หรือไม่ (จาก curl API)\"\"\"\n    try:\n        req = request.Request(f\"{API_URL}/system_stats\", method=\"GET\")\n        with request.urlopen(req, timeout=3) as resp:\n            return True\n    except Exception:\n        return False\n\ndef read_log(lines=50):\n    \"\"\"อ่าน log ล่าสุด N บรรทัด\"\"\"\n    if not os.path.exists(LOG_FILE):\n        return [\"(ยังไม่มีไฟล์ log)\"]\n    try:\n        with open(LOG_FILE, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n            all_lines = f.readlines()\n            return all_lines[-lines:] if len(all_lines) >= lines else all_lines\n    except Exception as e:\n        return [f\"Error reading log: {e}\"]\n\n# ─── Actions ──────────────────────────────────────────────\n\ndef do_status():\n    \"\"\"แสดงสถานะ ComfyUI\"\"\"\n    print(\"━\" * 45)\n    print(\"  🖥️  ComfyUI Server Status\")\n    print(\"━\" * 45)\n\n    running = is_running()\n    pids = get_pids_on_port(PORT)\n\n    print(f\"   API URL    : {API_URL}\")\n    print(f\"   Status     : {'✅ RUNNING' if running else '❌ STOPPED'}\")\n    print(f\"   Process IDs: {', '.join(pids) if pids else 'None'}\")\n    print(f\"   Log File   : {LOG_FILE}\")\n\n    if running:\n        try:\n            req = request.Request(f\"{API_URL}/system_stats\", method=\"GET\")\n            with request.urlopen(req, timeout=5) as resp:\n                stats = json.loads(resp.read().decode(\"utf-8\"))\n                if \"system\" in stats:\n                    sys_info = stats[\"system\"]\n                    vram = sys_info.get(\"vram\", {})\n                    print(f\"   GPU        : {vram.get('name', 'N/A')}\")\n                    print(f\"   VRAM Total : {vram.get('total', 'N/A')} MB\")\n                    print(f\"   VRAM Free  : {vram.get('free', 'N/A')} MB\")\n        except Exception:\n            pass\n\n    print(\"━\" * 45)\n\n\ndef do_start():\n    \"\"\"สตาร์ท ComfyUI ถ้ายังไม่รัน\"\"\"\n    if is_running():\n        print(\"✅ ComfyUI กำลังรันอยู่แล้ว\")\n        do_status()\n        return\n\n    print(\"🚀 กำลังสตาร์ท ComfyUI...\")\n\n    # Kill อันเก่า (ถ้ามีพวก zombie)\n    old_pids = get_pids_on_port(PORT)\n    if old_pids:\n        print(f\"⚠️  พบ process เก่าบน port {PORT}: {old_pids} — กำลัง kill...\")\n        kill_pids(old_pids)\n        time.sleep(2)\n\n    # ล้าง log เก่า (optional: backup ก่อน)\n    if os.path.exists(LOG_FILE):\n        backup = f\"{LOG_FILE}.old\"\n        try:\n            os.replace(LOG_FILE, backup)\n        except Exception:\n            pass\n\n    # Start ComfyUI\n    cmd = (\n        f\"cd {COMFYUI_DIR} && \"\n        f\"nohup {PYTHON_EXE} main.py --listen 0.0.0.0 --port {PORT} \"\n        f\"> {LOG_FILE} 2>&1 &\"\n    )\n    stdout, stderr, rc = run_cmd(cmd)\n    time.sleep(3)\n\n    # Verify\n    for attempt in range(10):\n        if is_running():\n            print(f\"✅ ComfyUI สตาร์ทสำเร็จ!\")\n            print(f\"   เข้าใช้งาน: {API_URL}\")\n            do_status()\n            return\n        time.sleep(1)\n\n    print(\"❌ สตาร์ทไม่สำเร็จ ดู log:\")\n    for line in read_log(20):\n        print(\"   \", line.rstrip())\n\n\ndef do_stop():\n    \"\"\"หยุด ComfyUI\"\"\"\n    pids = get_pids_on_port(PORT)\n    if not pids:\n        print(\"ℹ️  ไม่พบ ComfyUI process\")\n        return\n\n    print(f\"🛑 กำลังหยุด ComfyUI (PID: {', '.join(pids)})...\")\n    killed = kill_pids(pids)\n    time.sleep(2)\n\n    # เช็คว่าหยุดจริงไหม