{"type":"message","id":"3bae06cf","parentId":"e526d2f6","timestamp":"2026-05-07T15:45:35.550Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let's also check - on WSL, tkinter doesn't exist, but on Windows Python 3.12 it does. So sysmon.py will work when run on Windows.\n\nBut wait - get_cpu() and get_ram() use /proc/stat on Linux. On Windows they need to use different APIs. Let me add Windows support.","thinkingSignature":"860e15c0d2aab775031a61ff63ca1886fec8203365f7622592709414d9fdd178"},{"type":"toolCall","id":"call_function_y95o903oxdww_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Floating overlay: CPU + RAM + GPU % always-on-top.\"\"\"\nimport sys, os, time, subprocess, ctypes\n\nIS_WINDOWS = os.name == \"nt\"\n\n# ── Windows: CPU + RAM via ctypes ──\ndef get_cpu_win():\n    try:\n        kernel32 = ctypes.windll.kernel32\n        class FILETIME(ctypes.Structure):\n            _fields_ = [(\"dwLowDateTime\", ctypes.c_ulong),\n                        (\"dwHighDateTime\", ctypes.c_ulong)]\n        idle = FILETIME()\n        kernel = FILETIME()\n        user = FILETIME()\n        kernel32.GetSystemTimes(ctypes.byref(idle), ctypes.byref(kernel), ctypes.byref(user))\n        idle_t = idle.dwLowDateTime\n        kern_t = kernel.dwLowDateTime\n        user_t = user.dwLowDateTime\n        total = idle_t + kern_t + user_t\n        if hasattr(get_cpu_win, \"_prev\"):\n            d_total = total - get_cpu_win._prev[0]\n            d_idle = idle_t - get_cpu_win._prev[1]\n            pct = (d_idle / d_total * 100) if d_total else 0\n        else:\n            pct = 0\n        get_cpu_win._prev = (total, idle_t)\n        return round(pct, 1)\n    except Exception:\n        return 0\n\ndef get_ram_win():\n    try:\n        kernel32 = ctypes.windll.kernel32\n        c = ctypes.c_ulonglong()\n        kernel32.GlobalMemoryStatusEx(ctypes.byref(c))\n        return ctypes.c_ulonglong.from_buffer(c, 0).value & 0xFFFFFFFF\n    except Exception:\n        return 0\n\n# ── Linux: CPU via /proc/stat ──\n_prev_cpu = None\ndef get_cpu_linux():\n    global _prev_cpu\n    try:\n        with open(\"/proc/stat\") as f:\n            line = f.readline()\n        vals = [int(x) for x in line.split()[1:8]]\n        idle, total = vals[3], sum(vals)\n        if _prev_cpu is not None:\n            d_total = total - _prev_cpu[0]\n            d_idle = idle - _prev_cpu[1]\n            pct = round((1 - d_idle / d_total) * 100, 1) if d_total > 0 else 0\n        else:\n            pct = 0\n        _prev_cpu = (total, idle)\n        return max(0, pct)\n    except Exception:\n        return 0\n\ndef get_ram_linux():\n    try:\n        with open(\"/proc/meminfo\") as f:\n            data = f.read()\n        total = avail = 0\n        for line in data.splitlines():\n            parts = line.split()\n            if len(parts) < 2:\n                continue\n            k = parts[0].rstrip(':')\n            v = int(parts[1])\n            if k == \"MemTotal\":\n                total = v\n            elif k == \"MemAvailable\":\n                avail = v\n                break\n        if not avail:\n            for line in data.splitlines():\n                parts = line.split()\n                if len(parts) < 2:\n                    continue\n                if parts[0].rstrip(':') == \"MemFree\":\n                    avail = int(parts[1])\n                    break\n        if total:\n            return round((total - avail) / total * 100, 1)\n    except Exception:\n        pass\n    return 0\n\n# ── GPU via nvidia-smi ──\ndef get_gpu():\n    try:\n        if IS_WINDOWS:\n            r = subprocess.getoutput('nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits')\n        else:\n            r = subprocess.getoutput(\"nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null\").strip()\n        if r and r.strip().isdigit():\n            return int(r.strip())\n    except Exception:\n        pass\n    return None\n\ndef col(pct):\n    if pct >= 90: return \"#ff2222\"\n    if pct >= 70: return \"#ff8800\"\n    return \"#00ff88\"\n\n# ── Windows: always-on-top overlay ──\ndef windows_overlay():\n    import tkinter as tk\n\n    def get_cpu():\n        return get_cpu_win()\n    def get_ram():\n        try:\n            c = ctypes.c_ulonglong()\n            ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(c))\n            return c.value & 0xFFFFFFFF\n        except:\n            return 0\n\n    root = tk.Tk()\n    root.overrideredirect(True)\n    root.attributes(\"-topmost\", True)\n    root.configure(bg=\"#1a1a2e\")\n\n    sw = root.winfo_screenwidth()\n    sh = root.winfo_screenheight()\n    W, H = 170, 90\n    root.geometry(f\"{W}x{H}+{sw-W-15}+15\")\n\n    def drag_start(e):\n        root._x, root._y = e.x, e.y\n    def drag_move(e):\n        root.geometry(f\"+{e.x_root-root._x}+{e.y_root-root._y}\")\n\n    frm = tk.Frame(root, bg=\"#1a1a2e\", bd=0, padx=10, pady=6)\n    frm.pack(fill=\"both\", expand=True)\n    frm.bind(\"<Button-1>\", drag_start)\n    frm.bind(\"<B1-Motion>\", drag_move)\n\n    cpu_lbl = tk.Label(frm, text=\"CPU  --%\", font=(\"Consolas\", 14, \"bold\"), fg=\"#00ff88\", bg=\"#1a1a2e\", anchor=\"w\")\n    cpu_lbl.pack(fill=\"x\", pady=2)\n    ram_lbl = tk.Label(frm, text=\"RAM  --%\", font=(\"Consolas\", 14, \"bold\"), fg=\"#00ccff\", bg=\"#1a1a2e\", anchor=\"w\")\n    ram_lbl.pack(fill=\"x\", pady=2)\n    gpu_lbl = tk.Label(frm, text=\"GPU  --%\", font=(\"Consolas\", 14, \"bold\"), fg=\"#ff8800\", bg=\"#1a1a2e\", anchor=\"w\")\n    gpu_lbl.pack(fill=\"x\", pady=2)\n\n    _prev_ram = None\n    def update():\n        nonlocal _prev_ram\n        cpu = get_cpu()\n        ram = get_ram()\n        gpu = get_gpu()\n        cpu_lbl.config(text=f\"CPU  {cpu:5.1f}%\", fg=col(cpu))\n\n        if _prev_ram is not None and ram > 0:\n            ram_pct = ram\n            ram_lbl.config(text=f\"RAM  {ram_pct:5.1f}%\", fg=col(ram_pct))\n        elif ram > 0:\n            ram_lbl.config(text=f\"RAM  {ram:5.1f}%\", fg=col(ram))\n        _prev_ram = ram\n\n        if gpu is not None:\n            gpu_lbl.config(text=f\"GPU  {gpu:3d}%\", fg=col(gpu))\n        else:\n            gpu_lbl.config(text=\"GPU  N/A\", fg=\"#666666\")\n\n        root.after(1000, update)\n\n    root.after(500, update)\n    root.mainloop()\n\n# ── Linux: terminal bar ──\ndef terminal_bar():\n    print(\"Real-time CPU/RAM/GPU  (Ctrl+C to exit)\")\n    print(\"=\" * 55)\n    while True:\n        cpu = get_cpu_linux()\n        ram = get_ram_linux()\n        gpu = get_gpu()\n        ts = time.strftime(\"%H:%M:%S\")\n        g = f\" | GPU {gpu:3d}%\" if gpu else \" | GPU  N/A\"\n        print(f\"\\r  [{ts}]  CPU {cpu:5.1f}%  |  RAM {ram:5.1f}%{g}     \", end=\"\", flush=True)\n        time.sleep(1)\n\nif __name__ == \"__main__\":\n    if IS_WINDOWS:\n        windows_overlay()\n    else:\n        terminal_bar()\n","path":"/home/apinan/.openclaw/workspace/sysmon.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":107,"output":1904,"cacheRead":77888,"cacheWrite":0,"totalTokens":79899,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778168695343,"responseId":"064be678d6b6393fbbd103f00a6e3e9e"}}
