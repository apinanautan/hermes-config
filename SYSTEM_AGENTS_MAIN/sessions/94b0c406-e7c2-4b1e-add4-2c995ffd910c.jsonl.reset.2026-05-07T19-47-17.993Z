obal _cpu_started\n    if not _cpu_started:\n        t = threading.Thread(target=_reader, daemon=True)\n        t.start()\n        _cpu_started = True\n\n# ── Windows CPU (drain latest from thread-safe queue) ──\ndef get_cpu_win():\n    _ensure_cpu_thread()\n# drain all values, keep only the last one\n    latest = None\n    while True:\n        try: latest = _q.get_nowait()\n        except queue.Empty: break\n\n# ── Windows top proce\n... (truncated)"},"isError":false,"timestamp":1778172567306}}
{"type":"message","id":"085d83a3","parentId":"2b344144","timestamp":"2026-05-07T16:49:52.635Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see the problem. The `return` statement got lost and the function body is missing proper indentation. Let me just rewrite the whole file.","thinkingSignature":"9c324acf491d318d95d1b7ceb64af15c29290314b5a88e83304728e7a2a9ac25"},{"type":"toolCall","id":"call_function_co43l37gtkrc_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Floating CPU/GPU monitor — always-on-top overlay.\"\"\"\nimport sys, os, time, threading, queue\n\nIS_WINDOWS = os.name == \"nt\"\n\n# ── CPU reader thread: fresh 1s reading every iteration ──\n_q = queue.Queue()\n\ndef _reader():\n    import psutil\n    while True:\n        _q.put(psutil.cpu_percent(interval=1))\n\n_cpu_started = False\ndef _ensure_cpu_thread():\n    global _cpu_started\n    if not _cpu_started:\n        t = threading.Thread(target=_reader, daemon=True)\n        t.start()\n        _cpu_started = True\n\n# ── Windows CPU (drain latest from thread-safe queue) ──\ndef get_cpu_win():\n    _ensure_cpu_thread()\n    latest = None\n    while True:\n        try:\n            latest = _q.get_nowait()\n        except queue.Empty:\n            break\n    return round(latest, 1) if latest is not None else 0\n\n# ── Windows top process (CPU) ──\ndef get_top_cpu_proc():\n    try:\n        import psutil\n        procs = []\n        for p in psutil.process_iter([\"name\", \"cpu_percent\"]):\n            try:\n                c = p.cpu_percent(interval=0.1)\n                if c > 0.5:\n                    procs.append((c, p.name()))\n            except:\n                pass\n        procs.sort(key=lambda x: x[0], reverse=True)\n        if procs:\n            return procs[0][1][:20], procs[0][0]\n    except:\n        pass\n    return \"---\", 0\n\n# ── GPU via pynvml ──\n_gpu_init_ok = False\ndef _init_gpu():\n    global _gpu_init_ok\n    if not _gpu_init_ok:\n        try:\n            import pynvml\n            pynvml.nvmlInit()\n            _gpu_init_ok = True\n        except Exception:\n            _gpu_init_ok = False\n    return _gpu_init_ok\n\ndef get_gpu_info():\n    if not _init_gpu():\n        return None, \"---\"\n    try:\n        import pynvml\n        h = pynvml.nvmlDeviceGetHandleByIndex(0)\n        util = pynvml.nvmlDeviceGetUtilizationRates(h)\n        import subprocess\n        r = subprocess.getoutput(\n            'cmd /c nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>nul'\n        )\n        lines = [l.strip() for l in r.strip().splitlines() if l.strip()]\n        named = []\n        for line in lines:\n            parts = line.split(',')\n            if len(parts) < 3:\n                continue\n            name = parts[1].strip()\n            mem_str = parts[2].strip()\n            if not name or name in ('[Insufficient Permissions]', '[N/A]'):\n                continue\n            if mem_str in ('[N/A]', '0'):\n                continue\n            if '\\\\' in name:\n                name = name.split('\\\\')[-1]\n            mem_val = 0\n            try:\n                if 'MiB' in mem_str:\n                    mem_val = int(mem_str.split()[0])\n                elif 'GiB' in mem_str:\n                    mem_val = int(float(mem_str.split()[0]) * 1024)\n            except:\n                pass\n            named.append((mem_val, name[:20]))\n        named.sort(key=lambda x: x[0], reverse=True)\n        seen = set()\n        unique = []\n        for m, n in named:\n            if m > 0 and n.lower() not in seen:\n                seen.add(n.lower())\n                unique.append(n)\n        return int(util.gpu), unique[0] if unique else \"---\"\n    except Exception:\n        return None, \"---\"\n\ndef pct_col(p):\n    return \"#ff2222\" if p >= 90 else \"#ff8800\" if p >= 70 else \"#00ff88\"\n\ndef windows_overlay():\n    import tkinter as tk\n\n    root = tk.Tk()\n    root.overrideredirect(True)\n    root.attributes(\"-topmost\", True)\n    root.configure(bg=\"#111111\")\n\n    mon2_w, mon2_h = 1536, 864\n    W, H = 260, 130\n    x = 1536 + (mon2_w - W) - 20\n    y = 20\n    root.geometry(f\"{W}x{H}+{x}+{y}\")\n\n    def ds(e):\n        root._x, root._y = e.x, e.y\n    def dm(e):\n        root.geometry(f\"+{e.x_root-root._x}+{e.y_root-root._y}\")\n    root.bind(\"<Button-1>\", ds)\n    root.bind(\"<B1-Motion>\", dm)\n\n    font = (\"Consolas\", 16, \"bold\")\n    sub = (\"Consolas\", 12)\n\n    cpu_lbl = tk.Label(root, text=\"CPU : ---%\", bg=\"#111111\", fg=\"#00ff88\",\n                       font=font, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    cpu_lbl.pack(fill=\"x\")\n\n    cpu_name_lbl = tk.Label(root, text=\"---\", bg=\"#111111\", fg=\"#00ccff\",\n                             font=sub, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    cpu_name_lbl.pack(fill=\"x\")\n\n    gpu_lbl = tk.Label(root, text=\"GPU : ---%\", bg=\"#111111\", fg=\"#ff8800\",\n                       font=font, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    gpu_lbl.pack(fill=\"x\")\n\n    gpu_name_lbl = tk.Label(root, text=\"---\", bg=\"#111111\", fg=\"#ff8800\",\n                              font=sub, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    gpu_name_lbl.pack(fill=\"x\")\n\n    def update():\n        cpu = get_cpu_win()\n        cpu_name, _ = get_top_cpu_proc()\n        gpu, gpu_name = get_gpu_info()\n\n        cpu_lbl.config(text=f\"CPU : {cpu:.0f}%\", fg=pct_col(cpu))\n        cpu_name_lbl.config(text=f\"{cpu_name}\")\n        if gpu is not None:\n            gpu_lbl.config(text=f\"GPU : {gpu:.0f}%\", fg=pct_col(gpu))\n            gpu_name_lbl.config(text=f\"{gpu_name}\")\n        else:\n            gpu_lbl.config(text=\"GPU :  N/A\", fg=\"#888888\")\n            gpu_name_lbl.config(text=\"\")\n\n        root.after(1000, update)\n\n    root.after(500, update)\n    root.mainloop()\n\nif __name__ == \"__main__\":\n    if IS_WINDOWS:\n        windows_overlay()\n    else:\n        print(\"CPU/GPU monitor (Ctrl+C to exit)\")\n        while True:\n            cpu = get_cpu_win()\n            gpu, gn = get_gpu_info()\n            cpu_name, _ = get_top_cpu_proc()\n            g = f\" GPU {gpu:.0f}% ({gn})\" if gpu is not None else \" GPU  N/A\"\n            print(f\"\\r  {time.strftime('%H:%M:%S')}  CPU {cpu:.0f}% ({cpu_name}){g}     \", end=\"\", flush=True)\n            time.sleep(1)\n","path":"/home/apinan/.openclaw/workspace/sysmon.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":487,"output":1688,"cacheRead":152224,"cacheWrite":0,"totalTokens":154399,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778172567313,"responseId":"064bf59af38590c43cd9b96458600c7b"}}
