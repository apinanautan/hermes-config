{"type":"message","id":"5a019346","parentId":"a973d6c3","timestamp":"2026-05-07T15:57:28.310Z","message":{"role":"toolResult","toolCallId":"call_function_1njh9ob74gvl_1","toolName":"socraticode__codebase_search","content":[{"type":"text","text":"Search results for \"get_gpu nvidia-smi subprocess getoutput\" (5 matches):\n\n--- tg-to-dc.py (lines 1-62) [python] score: 0.6667 ---\n#!/usr/bin/env python3\n\"\"\"Send Telegram message to Discord DM\"\"\"\nimport os\nimport sys\nimport requests\n\nDISCORD_TOKEN = ***\"DISCORD_BOT_TOKEN\", \"\")\nDISCORD_USER_ID = \"817750913405157406\"\nDISCORD_API = \"https://discord.com/api/v10\"\n\ndef get_dm_channel():\n    \"\"\"Create/get DM channel with user.\"\"\"\n    headers = {\n        \"Authorization\": f\"Bot {DISCORD_TOKEN}\",\n        \"Content-Type\": \"application/json\"\n    }\n    r = requests.post(\n        f\"{DISCORD_API}/users/@me/channels\",\n        headers=headers,\n        json={\"recipient_id\": DISCORD_USER_ID},\n        timeout=10\n    )\n    if r.status_code == 200:\n        return r.json().get(\"id\")\n    print(f\"[TG->DC] Failed to create DM channel: {r.status_code} {r.text}\", file=sys.stderr)\n    return None\n\ndef send_to_discord(text):\n    if not text or text.strip() == \"\":\n        return True\n    \n    channel_id = get_dm_channel()\n    if not channel_id:\n        return False\n    \n    headers = {\n        \"Authorization\": f\"Bot {DISCORD_TOKEN}\",\n        \"Content-Type\": \"application/json\"\n    }\n    payload = {\n        \"content\": text\n    }\n    \n    r = requests.post(\n        f\"{DISCORD_API}/channels/{channel_id}/messages\",\n        headers=headers,\n        json=payload,\n        timeout=10\n    )\n    if r.status_code == 200:\n        print(f\"[TG->DC] Sent: {text[:50]}\")\n        return True\n    else:\n        print(f\"[TG->DC] Failed: {r.status_code} {r.text}\", file=sys.stderr)\n        return False\n\nif __name__ == \"__main__\":\n    text = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read().strip()\n    if text:\n        ok = send_to_discord(text)\n        sys.exit(0 if ok else 1)\n\n\n--- bridge-dc-listener.py (lines 57-98) [python] score: 0.6250 ---\n\ndef poll_discord(channel_id, last_msg_id):\n    headers = {\"Authorization\": f\"Bot {DISCORD_TOKEN}\"}\n    params = {\"limit\": 10}\n    if last_msg_id:\n        params[\"after\"] = last_msg_id\n\n    r = requests.get(\n        f\"{DISCORD_API}/channels/{channel_id}/messages\",\n        headers=headers,\n        params=params,\n        timeout=10\n    )\n    if r.status_code != 200:\n        print(f\"[Bridge] Discord poll error: {r.status_code}\")\n        return last_msg_id, []\n\n    messages = r.json()\n    new_messages = []\n    new_last_id = last_msg_id\n\n    # Discord returns newest first\n    for msg in reversed(messages):\n        mid = msg.get(\"id\")\n        author = msg.get(\"author\", {})\n        author_id = str(author.get(\"id\", \"\"))\n        text = msg.get(\"content\", \"\")\n\n        # Skip our own bot messages, empty messages\n        if author_id == DISCORD_BOT_ID or not text or not text.strip():\n            if mid and (not new_last_id or int(mid) > int(new_last_id)):\n                new_last_id = mid\n            continue\n\n        # Only relay messages from target user\n        if author_id == DISCORD_USER_ID:\n            new_messages.append(text)\n\n        if mid and (not new_last_id or int(mid) > int(new_last_id)):\n            new_last_id = mid\n\n    return new_last_id, new_messages\n\n--- pending-tasks.md (lines 1-19) [markdown] score: 0.5000 ---\n# Pending Tasks\n\n## งานหลัก: ChatGPT Web → รูป prop → Telegram\n- [x] หา/ติดตั้ง Microsoft UFO ให้เจอ path ชัดเจน: `C:\\Users\\Apinan\\Tools\\UFO`\n- [x] สร้าง venv + install requirements ของ UFO แล้ว: `C:\\Users\\Apinan\\Tools\\UFO\\.venv`\n- [x] Smoke test UFO: imports/API/help/no-op run ผ่าน\n- [ ] ตั้ง/ทดสอบ UFO ให้คุม Chrome/ChatGPT Web + custom GPT ได้จริง\n- [ ] ทำ wrapper command 