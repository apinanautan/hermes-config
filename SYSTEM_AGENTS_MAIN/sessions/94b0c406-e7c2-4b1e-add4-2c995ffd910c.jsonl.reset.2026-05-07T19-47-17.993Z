{"type":"message","id":"48e1487b","parentId":"80cc259a","timestamp":"2026-05-07T16:32:48.186Z","message":{"role":"toolResult","toolCallId":"call_function_cbjfqcov024v_1","toolName":"read","content":[{"type":"text","text":"    try:\n        import pynvml\n        h = pynvml.nvmlDeviceGetHandleByIndex(0)\n        util = pynvml.nvmlDeviceGetUtilizationRates(h)\n        import subprocess\n        r = subprocess.getoutput('cmd /c nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>nul')\n        lines = [l.strip() for l in r.strip().splitlines() if l.strip()]\n        names = []\n        for line in lines:\n            parts = line.split(',')\n            if len(parts) >= 3:\n                name = parts[1].strip()\n                mem = parts[2].strip()\n                if name and name not in ('[Insufficient Permissions]', '[N/A]') and mem not in ('[N/A]', '0'):\n                    if '\\\\' in name:\n                        name = name.split('\\\\')[-1]\n                    names.append(name[:20])\n        names_mem = []\n        for line in lines:\n            parts = line.split(',')\n            if len(parts) >= 3:\n                name = parts[1].strip()\n                mem_str = parts[2].strip()\n                if name and name not in ('[Insufficient Permissions]', '[N/A]'):\n                    if '\\\\' in name:\n                        name = name.split('\\\\')[-1]\n                    # parse memory like \"123 MiB\" or \"N/A\"\n                    mem_val = 0\n                    if 'MiB' in mem_str:\n                        try: mem_val = int(mem_str.split()[0])\n                        except: pass\n                    elif 'GiB' in mem_str:\n                        try: mem_val = int(float(mem_str.split()[0]) * 1024)\n                        except: pass\n                    names_mem.append((mem_val, name))\n        # sort by memory descending\n        names_mem.sort(key=lambda x: x[0], reverse=True)\n        unique = []\n        seen = set()\n        for m, n in names_mem:\n            if m > 0 and n.lower() not in seen:\n                seen.add(n.lower())\n                unique.append(n)\n        return int(util.gpu), unique[0] if unique else \"---\"\n    except Exception:\n        return None, \"---\"\n\ndef pct_col(p):\n    return \"#ff2222\" if p >= 90 else \"#ff8800\" if p >= 70 else \"#00ff88\"\n\n\n[73 more lines in file. Use offset=115 to continue.]"}],"isError":false,"timestamp":1778171568186}}
{"type":"message","id":"8c366c28","parentId":"48e1487b","timestamp":"2026-05-07T16:33:09.914Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see the issue — there's a duplicate block. The old `names = []` loop is still there. Let me write the whole file fresh to fix it properly.","thinkingSignature":"fea6dc421abbb7d41fa28f1da1e52764a7d6960c2033d0682551d57ccd6db2c4"},{"type":"text","text":"\n\n\nที่เห็นมันซ้ำกัน 2 รอบ เดี๋ยวเขียนใหม่เลยดีกว่า\n"},{"type":"toolCall","id":"call_function_t38dk1g6d5nm_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Floating CPU/GPU monitor — always-on-top overlay.\"\"\"\nimport sys, os, time\n\nIS_WINDOWS = os.name == \"nt\"\n\n# ── Windows CPU (system-wide via psutil) ──\n_cpu_cache = None\n_last_cpu_time = 0\ndef get_cpu_win():\n    global _cpu_cache, _last_cpu_time\n    now = time.time()\n    try:\n        import psutil\n        if _cpu_cache is None:\n            # first call: block 1s to get initial reading\n            _cpu_cache = psutil.cpu_percent(interval=1)\n            _last_cpu_time = now\n            return round(_cpu_cache, 1)\n        elif now - _last_cpu_time >= 1.0:\n            # fresh reading (psutil caches internally, ~1s)\n            _cpu_cache = psutil.cpu_percent(interval=None)\n            _last_cpu_time = now\n        return round(_cpu_cache, 1)\n    except:\n        return 0\n\n# ── Windows top process (CPU) ──\ndef get_top_cpu_proc():\n    try:\n        import psutil\n        procs = []\n        for p in psutil.process_iter([\"name\", \"cpu_percent\"]):\n            try:\n                c = p.cpu_percent(interval=0.1)\n                if c > 0.5:\n                    procs.append((c, p.name()))\n            except:\n                pass\n        procs.sort(key=lambda x: x[0], reverse=True)\n        if procs:\n            return procs[0][1][:20], procs[0][0]\n    except:\n        pass\n    return \"---\", 0\n\n# ── GPU via pynvml ──\n_gpu_init_ok = False\ndef _init_gpu():\n    global _gpu_init_ok\n    if not _gpu_init_ok:\n        try:\n            import pynvml\n            pynvml.nvmlInit()\n            _gpu_init_ok = True\n        except Exception:\n            _gpu_init_ok = False\n    return _gpu_init_ok\n\ndef get_gpu_info():\n    if not _init_gpu():\n        return None, \"---\"\n    try:\n        import pynvml\n        h = pynvml.nvmlDeviceGetHandleByIndex(0)\n        util = pynvml.nvmlDeviceGetUtilizationRates(h)\n        import subprocess\n        r = subprocess.getoutput(\n            'cmd /c nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>nul'\n        )\n        lines = [l.strip() for l in r.strip().splitlines() if l.strip()]\n        # Collect (memory_bytes, name) for processes with real GPU memory usage\n        named = []\n        for line in lines:\n            parts = line.split(',')\n            if len(parts) < 3:\n                continue\n            name = parts[1].strip()\n            mem_str = parts[2].strip()\n            if not name or name in ('[Insufficient Permissions]', '[N/A]'):\n                continue\n            if mem_str in ('[N/A]', '0'):\n                continue\n            # Shorten path\n            if '\\\\' in name:\n                name = name.split('\\\\')[-1]\n            # Parse memory — \"123 MiB\" or \"1.2 GiB\"\n            mem_val = 0\n            try:\n                if 'MiB' in mem_str:\n                    mem_val = int(mem_str.split()[0])\n                elif 'GiB' in mem_str:\n                    mem_val = int(float(mem_str.split()[0]) * 1024)\n            except:\n                pass\n            named.append((mem_val, name[:20]))\n        # Sort by memory, dedup, return top by GPU memory\n        named.sort(key=lambda x: x[0], reverse=True)\n        seen = set()\n        unique = []\n        for m, n in named:\n            if m > 0 and n.lower() not in seen:\n                seen.add(n.lower())\n                unique.append(n)\n        return int(util.gpu), unique[0] if unique else \"---\"\n    except Exception:\n        return None, \"---\"\n\ndef pct_col(p):\n    return \"#ff2222\" if p >= 90 else \"#ff8800\" if p >= 70 else \"#00ff88\"\n\ndef windows_overlay():\n    import tkinter as tk\n\n    root = tk.Tk()\n    root.overrideredirect(True)\n    root.attributes(\"-topmost\", True)\n    root.configure(bg=\"#111111\")\n\n    mon2_w, mon2_h = 1536, 864\n    W, H = 260, 130\n    x = 1536 + (mon2_w - W) - 20\n    y = 20\n    root.geometry(f\"{W}x{H}+{x}+{y}\")\n\n    def ds(e): root._x, root._y = e.x, e.y\n    def dm(e): root.geometry(f\"+{e.x_root-root._x}+{e.y_root-root._y}\")\n    root.bind(\"<Button-1>\", ds)\n    root.bind(\"<B1-Motion>\", dm)\n\n    font = (\"Consolas\", 16, \"bold\")\n    sub = (\"Consolas\", 12)\n\n    cpu_lbl = tk.Label(root, text=\"CPU : ---%\", bg=\"#111111\", fg=\"#00ff88\",\n                       font=font, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    cpu_lbl.pack(fill=\"x\")\n\n    cpu_name_lbl = tk.Label(root, text=\"---\", bg=\"#111111\", fg=\"#00ccff\",\n                             font=sub, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    cpu_name_lbl.pack(fill=\"x\")\n\n    gpu_lbl = tk.Label(root, text=\"GPU : ---%\", bg=\"#111111\", fg=\"#ff8800\",\n                       font=font, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    gpu_lbl.pack(fill=\"x\")\n\n    gpu_name_lbl = tk.Label(root, text=\"---\", bg=\"#111111\", fg=\"#ff8800\",\n                              font=sub, anchor=\"w\", padx=10, pady=3, relief=\"flat\", bd=0)\n    gpu_name_lbl.pack(fill=\"x\")\n\n    def update():\n        cpu = get_cpu_win()\n        cpu_name, cpu_val = get_top_cpu_proc()\n        gpu, gpu_name = get_gpu_info()\n\n        cpu_lbl.config(text=f\"CPU : {cpu:.0f}%\", fg=pct_col(cpu))\n        cpu_name_lbl.config(text=f\"{cpu_name} {cpu_val:.0f}%\")\n        if gpu is not None:\n            gpu_lbl.config(text=f\"GPU : {gpu:.0f}%\", fg=pct_col(gpu))\n            gpu_name_lbl.config(text=f\"{gpu_name}\")\n        else:\n            gpu_lbl.config(text=\"GPU :  N/A\", fg=\"#888888\")\n            gpu_name_lbl.config(text=\"\")\n\n        root.after(1000, update)\n\n    root.after(500, update)\n    root.mainloop()\n\ndef terminal_bar():\n    print(\"CPU/GPU monitor (Ctrl+C to exit)\")\n    while True:\n        cpu = get_cpu_win()\n        gpu, gpu_names = get_gpu_info()\n        cpu_name, cpu_val = get_top_cpu_proc()\n        g = f\" GPU {gpu:.0f}% ({gpu_names})\" if gpu is not None else \" GPU  N/A\"\n        print(f\"\\r  {time.strftime('%H:%M:%S')}  CPU {cpu:.0f}% ({cpu_name} {cpu_val:.0f}%){g}     \", end=\"\", flush=True)\n        time.sleep(1)\n\nif __name__ == \"__main__\":\n    if IS_WINDOWS:\n        windows_overlay()\n    else:\n        terminal_bar()\n","path":"/home/apinan/.openclaw/workspace/sysmon.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":615,"output":1829,"cacheRead":138592,"cacheWrite":0,"totalTokens":141036,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778171568194,"responseId":"064bf1b2bf86408dd69643876e336cee"}}
