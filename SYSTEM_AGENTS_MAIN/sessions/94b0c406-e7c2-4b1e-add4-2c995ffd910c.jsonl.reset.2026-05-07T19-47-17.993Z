{"type":"message","id":"ef49589a","parentId":"de119ffb","timestamp":"2026-05-07T15:42:18.605Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants an overlay ON SCREEN - not in terminal. On Windows, I should use tkinter with topmost. Let me fix the code properly.\n","thinkingSignature":"96c1c2a5ccbb224a7c1b0a6b665034bea832277870c4f76d55d74cb2869cbdc7"},{"type":"toolCall","id":"call_function_89mld60aey0q_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Floating overlay: CPU + RAM + GPU % — always-on-top window.\"\"\"\nimport sys, os, time, subprocess\n\nIS_WINDOWS = os.name == \"nt\"\n\n# ── CPU via /proc/stat ──\n_prev_cpu = None\ndef get_cpu():\n    global _prev_cpu\n    try:\n        with open(\"/proc/stat\") as f:\n            line = f.readline()\n        vals = [int(x) for x in line.split()[1:8]]\n        idle, total = vals[3], sum(vals)\n        if _prev_cpu is not None:\n            d_total = total - _prev_cpu[0]\n            d_idle = idle - _prev_cpu[1]\n            pct = round((1 - d_idle / d_total) * 100, 1) if d_total > 0 else 0\n        else:\n            pct = 0\n        _prev_cpu = (total, idle)\n        return max(0, pct)\n    except Exception:\n        out = subprocess.getoutput(\"top -bn1 | grep 'Cpu(s)' | awk '{print $2}'\").strip().replace(',','.')\n        return round(100 - float(out), 1) if out else 0\n\n# ── RAM via /proc/meminfo ──\ndef get_ram():\n    try:\n        with open(\"/proc/meminfo\") as f:\n            data = f.read()\n        total = avail = 0\n        for line in data.splitlines():\n            parts = line.split()\n            if len(parts) < 2:\n                continue\n            k = parts[0].rstrip(':')\n            v = int(parts[1])\n            if k == \"MemTotal\":\n                total = v\n            elif k == \"MemAvailable\":\n                avail = v\n                break\n        if not avail:\n            for line in data.splitlines():\n                parts = line.split()\n                if len(parts) < 2:\n                    continue\n                if parts[0].rstrip(':') == \"MemFree\":\n                    avail = int(parts[1])\n                    break\n        if total:\n            return round((total - avail) / total * 100, 1)\n    except Exception:\n        pass\n    return 0\n\n# ── GPU via nvidia-smi ──\ndef get_gpu():\n    try:\n        r = subprocess.getoutput(\"nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null\").strip()\n        if r and r.isdigit():\n            return int(r)\n    except Exception:\n        pass\n    return None\n\ndef col(pct):\n    if pct >= 90: return \"#ff2222\"\n    if pct >= 70: return \"#ff8800\"\n    return \"#00ff88\"\n\n# ── WINDOWS: always-on-top overlay ──\ndef windows_overlay():\n    import tkinter as tk\n\n    root = tk.Tk()\n    root.overrideredirect(True)           # no title bar\n    root.attributes(\"-topmost\", True)     # always on top\n    root.configure(bg=\"#1a1a2e\")\n\n    sw = root.winfo_screenwidth()\n    sh = root.winfo_screenheight()\n    W, H = 170, 88\n    root.geometry(f\"{W}x{H}+{sw-W-15}+{sh-H-15}\")\n\n    # Draggable\n    def drag_start(e):\n        root._x, root._y = e.x, e.y\n    def drag_move(e):\n        root.geometry(f\"+{e.x_root-root._x}+{e.y_root-root._y}\")\n\n    frm = tk.Frame(root, bg=\"#1a1a2e\", bd=0, padx=10, pady=6)\n    frm.pack(fill=\"both\", expand=True)\n    frm.bind(\"<Button-1>\", drag_start)\n    frm.bind(\"<B1-Motion>\", drag_move)\n\n    cpu_lbl = tk.Label(frm, text=\"CPU  --%\",\n                       font=(\"Consolas\", 13, \"bold\"),\n                       fg=\"#00ff88\", bg=\"#1a1a2e\", anchor=\"w\")\n    cpu_lbl.pack(fill=\"x\", pady=2)\n\n    ram_lbl = tk.Label(frm, text=\"RAM  --%\",\n                       font=(\"Consolas\", 13, \"bold\"),\n                       fg=\"#00ccff\", bg=\"#1a1a2e\", anchor=\"w\")\n    ram_lbl.pack(fill=\"x\", pady=2)\n\n    gpu_lbl = tk.Label(frm, text=\"GPU  --%\",\n                       font=(\"Consolas\", 13, \"bold\"),\n                       fg=\"#ff8800\", bg=\"#1a1a2e\", anchor=\"w\")\n    gpu_lbl.pack(fill=\"x\", pady=2)\n\n    def update():\n        cpu = get_cpu()\n        ram = get_ram()\n        gpu = get_gpu()\n\n        cpu_lbl.config(text=f\"CPU  {cpu:5.1f}%\", fg=col(cpu))\n        ram_lbl.config(text=f\"RAM  {ram:5.1f}%\", fg=col(ram))\n        if gpu is not None:\n            gpu_lbl.config(text=f\"GPU  {gpu:3d}%\", fg=col(gpu))\n        else:\n            gpu_lbl.config(text=\"GPU  N/A\", fg=\"#666666\")\n\n        root.after(1000, update)\n\n    root.after(500, update)\n    root.mainloop()\n\n# ── Linux/macOS: terminal bar ──\ndef terminal_bar():\n    print(\"Real-time CPU/RAM/GPU  (Ctrl+C to exit)\")\n    print(\"=\" * 55)\n    while True:\n        cpu = get_cpu()\n        ram = get_ram()\n        gpu = get_gpu()\n        ts = time.strftime(\"%H:%M:%S\")\n        g = f\" | GPU {gpu:3d}%\" if gpu else \" | GPU  N/A\"\n        print(f\"\\r  [{ts}]  CPU {cpu:5.1f}%  |  RAM {ram:5.1f}%{g}     \", end=\"\", flush=True)\n        time.sleep(1)\n\nif __name__ == \"__main__\":\n    if IS_WINDOWS:\n        windows_overlay()\n    else:\n        terminal_bar()\n","path":"/home/apinan/.openclaw/workspace/sysmon.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":162,"output":1427,"cacheRead":75040,"cacheWrite":0,"totalTokens":76629,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778168522303,"responseId":"064be5cbd66bb44b79c546d7c9ea14d6"}}
