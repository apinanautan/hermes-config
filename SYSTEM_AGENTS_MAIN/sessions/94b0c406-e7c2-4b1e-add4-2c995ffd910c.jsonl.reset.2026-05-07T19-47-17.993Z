{"type":"message","id":"03995cfd","parentId":"1b23b971","timestamp":"2026-05-07T15:39:01.804Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants the numbers to show on the computer screen - like an overlay, not in a terminal. Something that floats on top of everything. On Windows, this could be a small floating widget/overlay. On Linux/WSL, maybe a small PySimpleGUI or tkinter window that stays on top.\n\nLet me make a small floating overlay window.\n","thinkingSignature":"b03228ac7729eb61176f40ab18d259d8e36a842f7b26167742cf2d62f60e8548"},{"type":"toolCall","id":"call_function_lxmnt5hnm8r4_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Floating overlay: CPU + RAM + GPU % on screen (top-most window).\"\"\"\nimport sys\nimport os\nimport time\nimport ctypes\nimport ctypes.wintypes as wintypes\n\nIS_WINDOWS = os.name == \"nt\"\n\ndef get_cpu():\n    try:\n        import psutil\n        return psutil.cpu_percent(interval=0.1)\n    except Exception:\n        out = os.popen(\"top -bn1 | grep 'Cpu(s)' | awk '{print $2}'\").read()\n        idle = float(out.strip().replace(',', '.')) if out.strip() else 0\n        return round(100 - idle, 1)\n\ndef get_ram():\n    try:\n        import psutil\n        m = psutil.virtual_memory()\n        return m.percent\n    except Exception:\n        out = os.popen(\"free -h | grep Mem\").read().split()\n        if len(out) >= 4:\n            used = float(out[2].rstrip('Gi'))\n            total = float(out[1].rstrip('Gi'))\n            return int(used / total * 100)\n        return 0\n\ndef get_gpu():\n    try:\n        if IS_WINDOWS:\n            r = os.popen(\"nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits\").read()\n        else:\n            r = os.popen(\"nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null\").read()\n        if r.strip():\n            return int(r.strip())\n    except Exception:\n        pass\n    return None\n\n# ── Windows: tiny always-on-top overlay via tkinter + win32api ──\ndef windows_overlay():\n    try:\n        import tkinter as tk\n    except ImportError:\n        print(\"tkinter not available\")\n        sys.exit(1)\n\n    import psutil\n    mem = psutil.virtual_memory()\n\n    root = tk.Tk()\n    root.overrideredirect(True)          # no borders\n    root.attributes(\"-topmost\", True)    # always on top\n    root.attributes(\"-transparentcolor\", \"black\")\n    root.configure(bg=\"black\")\n\n    # Position: top-right, 10px from edges\n    sw = root.winfo_screenwidth()\n    sh = root.winfo_screenheight()\n    W, H = 180, 90\n    root.geometry(f\"{W}x{H}+{sw-W-10}+10\")\n\n    # Draggable\n    def drag_start(e):\n        root._drag_x = e.x\n        root._drag_y = e.y\n    def drag_move(e):\n        root.geometry(f\"+{e.x_root-root._drag_x}+{e.y_root-root._drag_y}\")\n\n    frame = tk.Frame(root, bg=\"black\", bd=0, padx=8, pady=6)\n    frame.pack(fill=\"both\", expand=True)\n    frame.bind(\"<Button-1>\", drag_start)\n    frame.bind(\"<B1-Motion>\", drag_move)\n\n    cpu_label = tk.Label(frame, text=\"CPU  --%\", font=(\"Consolas\", 14, \"bold\"),\n                         fg=\"#00ff88\", bg=\"black\", anchor=\"w\")\n    cpu_label.pack(fill=\"x\")\n\n    ram_label = tk.Label(frame, text=\"RAM  --%\", font=(\"Consolas\", 14, \"bold\"),\n                         fg=\"#00ccff\", bg=\"black\", anchor=\"w\")\n    ram_label.pack(fill=\"x\")\n\n    gpu_label = tk.Label(frame, text=\"GPU  --%\", font=(\"Consolas\", 14, \"bold\"),\n                         fg=\"#ff8800\", bg=\"black\", anchor=\"w\")\n    gpu_label.pack(fill=\"x\")\n\n    def color(pct):\n        if pct >= 90: return \"#ff2222\"\n        if pct >= 70: return \"#ff8800\"\n        return \"#00ff88\"\n\n    def update():\n        cpu = get_cpu()\n        ram = mem.percent\n        gpu = get_gpu()\n\n        cpu_label.config(text=f\"CPU  {cpu:5.1f}%\", fg=color(cpu))\n        ram_label.config(text=f\"RAM  {ram:5.1f}%\", fg=color(ram))\n        if gpu is not None:\n            gpu_label.config(text=f\"GPU  {gpu:3d}%\", fg=color(gpu))\n        else:\n            gpu_label.config(text=\"GPU  N/A \", fg=\"#666666\")\n\n        mem.refresh()\n        root.after(1000, update)\n\n    root.after(500, update)\n    root.mainloop()\n\n\n# ── Linux/macOS: simple terminal bar ──\ndef terminal_bar():\n    print(\"Real-time CPU/RAM monitor  (Ctrl+C to exit)\")\n    try:\n        import psutil\n    except Exception:\n        os.system(\"pip install psutil\")\n        import psutil\n\n    mem = psutil.virtual_memory()\n    while True:\n        cpu = get_cpu()\n        mem.refresh()\n        gpu = get_gpu()\n        ts = time.strftime(\"%H:%M:%S\")\n        g = f\" GPU {gpu:3d}%\" if gpu else \" GPU  N/A\"\n        print(f\"\\r[{ts}] CPU {cpu:5.1f}%  RAM {mem.percent:5.1f}%{g}   \", end=\"\", flush=True)\n        time.sleep(1)\n\nif __name__ == \"__main__\":\n    if IS_WINDOWS:\n        windows_overlay()\n    else:\n        terminal_bar()\n","path":"/home/apinan/.openclaw/workspace/sysmon.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":1982,"output":1296,"cacheRead":66464,"cacheWrite":0,"totalTokens":69742,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778168322379,"responseId":"064be504aadd70b18c6387dd295f0cb8"}}
