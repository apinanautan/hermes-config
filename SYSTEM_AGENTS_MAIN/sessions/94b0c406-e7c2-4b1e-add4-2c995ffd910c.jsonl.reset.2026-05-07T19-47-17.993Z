=headers,\n        json={\"recipient_id\": DISCORD_USER_ID},\n        timeout=10\n    )\n    if r.status_code == 200:\n        return r.json().get(\"id\")\n    print(f\"[TG->DC] Failed to create DM channel: {r.status_code} {r.text}\", file=sys.stderr)\n    return None\n\ndef send_to_discord(text):\n    if not text or text.strip() == \"\":\n        return True\n    \n    channel_id = get_dm_channel()\n    if not channel_id:\n        return False\n    \n    headers = {\n        \"Authorization\": f\"Bot {DISCORD_TOKEN}\",\n        \"Content-Type\": \"application/json\"\n    }\n    payload = {\n        \"content\": text\n    }\n    \n    r = requests.post(\n        f\"{DISCORD_API}/channels/{channel_id}/messages\",\n        headers=headers,\n        json=payload,\n        timeout=10\n    )\n    if r.status_code == 200:\n        print(f\"[TG->DC] Sent: {text[:50]}\")\n        return True\n    else:\n        print(f\"[TG->DC] Failed: {r.status_code} {r.text}\", file=sys.stderr)\n        return False\n\nif __name__ == \"__main__\":\n    text = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read().strip()\n    if text:\n        ok = send_to_discord(text)\n        sys.exit(0 if ok else 1)\n\n\n--- bridge-dc-listener.py (lines 1-22) [python] score: 0.2500 ---\n#!/usr/bin/env python3\n\"\"\"\nDiscord -> Telegram auto-relay daemon.\nPolls Discord DM via HTTP API (no WebSocket needed).\nNo extra dependencies beyond requests (usually pre-installed).\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport requests\n\nTELEGRAM_BOT_TOKEN = \"867401…uE0o\"\nTELEGRAM_CHAT_ID = \"1060942816\"\nTELEGRAM_API = f\"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}\"\n\nDISCORD_TOKEN = ***\"DISCORD_BOT_TOKEN\", \"\")\nDISCORD_USER_ID = \"817750913405157406\"\nDISCORD_BOT_ID = \"1501840762193711188\"\nDISCORD_API = \"https://discord.com/api/v10\"\n\n"}],"details":{"mcpServer":"socraticode","mcpTool":"codebase_search"},"isError":false,"timestamp":1778169470190}}
