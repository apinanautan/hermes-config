state, last_msg_id={last_msg_id}\")\n        except Exception:\n            pass\n\n    # On first run, fetch latest message ID but don't relay history\n    if last_msg_id is None:\n        headers = {\"Authorization\": f\"Bot {DISCORD_TOKEN}\"}\n        r = requests.get(f\"{DISCORD_API}/channels/{channel_id}/messages?limit=1\", headers=headers, timeout=10)\n        if r.status_code == 200:\n            msgs = r.json()\n            if msgs:\n                last_msg_id = msgs[0].get(\"id\")\n                print(f\"[Bridge] First run, synced to latest message id={last_msg_id}\")\n\n    print(\"[Bridge] Polling started (Ctrl+C to stop)\")\n\n    while True:\n        try:\n            last_msg_id, messages = poll_discord(channel_id, last_msg_id)\n            for text in messages:\n                print(f\"[Bridge] DC -> TG: {text[:50]}\")\n                send_to_telegram(text)\n            # Save state\n            try:\n                with open(state_file, \"w\") as f:\n                    json.dump({\"last_msg_id\": last_msg_id}, f)\n            except Exception:\n                pass\n        except Exception as e:\n            print(f\"[Bridge] Error: {e}\")\n\n        time.sleep(2)\n"}],"details":{"mcpServer":"socraticode","mcpTool":"codebase_search"},"isError":false,"timestamp":1778169448310}}
