n    prune_summaries\n    \n    log \"=== Check complete: $compacted/$total sessions compacted ===\"\n}\n\n# Show status\nshow_status() {\n    log \"=== Session Status ===\"\n    while IFS= read -r session_key; do\n        [ -z \"$session_key\" ] && continue\n        local session_file\n        session_file=$(get_session_file \"$session_key\")\n        [ -z \"$session_file\" ] || [ ! -f \"$session_file\" ] && continue\n        local ctx_pct msg_count\n        ctx_pct=$(estimate_context \"$session_file\")\n        msg_count=$(count_messages \"$session_file\")\n        msg_count=$(echo \"$msg_count\" | tr -d '[:space:]')\n        [ -z \"$msg_count\" ] && msg_count=0\n        log \"STATUS: $session_key | context: ${ctx_pct}% | messages: $msg_count\"\n    done < <(list_sessions)\n}\n\n# Main\ncase \"${1:-check}\" in\n    check)    run_check ;;\n    status)   show_status ;;\n    compact)  compact_session \"${2:-}\" \"${3:-}\" ;;\n    *)        echo \"Usage: $0 {check|status|compact <key> <file>}\" ;;\nesac","path":"/home/apinan/.openclaw/scripts/openclaw-auto-compact.sh"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":1544,"output":2263,"cacheRead":46400,"cacheWrite":0,"totalTokens":50207,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778426615466,"responseId":"064fd5f920d4d2766c141e2b9b047a5b"}}
