{"type":"message","id":"5b4c8ef5","parentId":"59e3a214","timestamp":"2026-05-07T09:17:00.222Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"ต้องเขียนไฟล์ใหม่เลยเพราะ edit ไม่เจอ exact match","thinkingSignature":"reasoning"},{"type":"toolCall","id":"functions.write:104","name":"write","arguments":{"path":"/home/apinan/.openclaw/workspace/bridge-dc-listener.py","content":"#!/usr/bin/env python3\n\"\"\"\nDiscord -> Telegram auto-relay daemon.\nPolls Discord DM via HTTP API (no WebSocket needed).\nNo extra dependencies beyond requests (usually pre-installed).\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport requests\n\nTELEGRAM_BOT_TOKEN = \"8674013658:AAEK6ot7k9xxhoBWFXX5MnpWnA6Jru5uE0o\"\nTELEGRAM_CHAT_ID = \"1060942816\"\nTELEGRAM_API = f\"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}\"\n\nDISCORD_TOKEN = os.environ.get(\"DISCORD_BOT_TOKEN\", \"\")\nDISCORD_USER_ID = \"817750913405157406\"\nDISCORD_BOT_ID = \"1501840762193711188\"\nDISCORD_API = \"https://discord.com/api/v10\"\n\ndef send_to_telegram(text):\n    if not text or text.strip() == \"\":\n        return True\n    try:\n        payload = {\"chat_id\": TELEGRAM_CHAT_ID, \"text\": text}\n        r = requests.post(f\"{TELEGRAM_API}/sendMessage\", json=payload, timeout=10)\n        if r.status_code == 200:\n            print(f\"[DC->TG] Sent: {text[:50]}\")\n            return True\n        else:\n            print(f\"[DC->TG] Failed: {r.status_code} {r.text}\", file=sys.stderr)\n            return False\n    except Exception as e:\n        print(f\"[DC->TG] Error: {e}\", file=sys.stderr)\n        return False\n\ndef get_dm_channel():\n    headers = {\n        \"Authorization\": f\"Bot {DISCORD_TOKEN}\",\n        \"Content-Type\": \"application/json\"\n    }\n    r = requests.post(\n        f\"{DISCORD_API}/users/@me/channels\",\n        headers=headers,\n        json={\"recipient_id\": DISCORD_USER_ID},\n        timeout=10\n    )\n    if r.status_code == 200:\n        cid = r.json().get(\"id\")\n        print(f\"[Bridge] Discord DM channel: {cid}\")\n        return cid\n    else:\n        print(f\"[Bridge] Failed to create DM: {r.status_code} {r.text}\")\n        return None\n\ndef poll_discord(channel_id, last_msg_id):\n    headers = {\"Authorization\": f\"Bot {DISCORD_TOKEN}\"}\n    params = {\"limit\": 10}\n    if last_msg_id:\n        params[\"after\"] = last_msg_id\n\n    r = requests.get(\n        f\"{DISCORD_API}/channels/{channel_id}/messages\",\n        headers=headers,\n        params=params,\n        timeout=10\n    )\n    if r.status_code != 200:\n        print(f\"[Bridge] Discord poll error: {r.status_code}\")\n        return last_msg_id, []\n\n    messages = r.json()\n    new_messages = []\n    new_last_id = last_msg_id\n\n    # Discord returns newest first\n    for msg in reversed(messages):\n        mid = msg.get(\"id\")\n        author = msg.get(\"author\", {})\n        author_id = str(author.get(\"id\", \"\"))\n        text = msg.get(\"content\", \"\")\n\n        # Skip our own bot messages, empty messages\n        if author_id == DISCORD_BOT_ID or not text or not text.strip():\n            if mid and (not new_last_id or int(mid) > int(new_last_id)):\n                new_last_id = mid\n            continue\n\n        # Only relay messages from target user\n        if author_id == DISCORD_USER_ID:\n            new_messages.append(text)\n\n        if mid and (not new_last_id or int(mid) > int(new_last_id)):\n            new_last_id = mid\n\n    return new_last_id, new_messages\n\ndef main():\n    if not DISCORD_TOKEN:\n        print(\"[Bridge] ERROR: DISCORD_BOT_TOKEN not set!\")\n        sys.exit(1)\n\n    print(\"[Bridge] Starting Discord -> Telegram relay...\")\n    channel_id = get_dm_channel()\n    if not channel_id:\n        print(\"[Bridge] ERROR: No DM channel. Exiting.\")\n        sys.exit(1)\n\n    last_msg_id = None\n    state_file = \"/home/apinan/.openclaw/workspace/bridge-dc-state.json\"\n    if os.path.exists(state_file):\n        try:\n            with open(state_file) as f:\n                saved = json.load(f)\n                last_msg_id = saved.get(\"last_msg_id\")\n                print(f\"[Bridge] Resumed from state, last_msg_id={last_msg_id}\")\n        except Exception:\n            pass\n\n    # On first run, fetch latest message ID but don't relay history\n    if last_msg_id is None:\n        headers = {\"Authorization\": f\"Bot {DISCORD_TOKEN}\"}\n        r = requests.get(f\"{DISCORD_API}/channels/{channel_id}/messages?limit=1\", headers=headers, timeout=10)\n        if r.status_code == 200:\n            msgs = r.json()\n            if msgs:\n                last_msg_id = msgs[0].get(\"id\")\n                print(f\"[Bridge] First run, synced to latest message id={last_msg_id}\")\n\n    print(\"[Bridge] Polling started (Ctrl+C to stop)\")\n\n    while True:\n        try:\n            last_msg_id, messages = poll_discord(channel_id, last_msg_id)\n            for text in messages:\n                print(f\"[Bridge] DC -> TG: {text[:50]}\")\n                send_to_telegram(text)\n            # Save state\n            try:\n                with open(state_file, \"w\") as f:\n                    json.dump({\"last_msg_id\": last_msg_id}, f)\n            except Exception:\n                pass\n        except Exception as e:\n            print(f\"[Bridge] Error: {e}\")\n\n        time.sleep(2)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"ollama-pay","model":"kimi-k2.6:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778145398925,"responseId":"chatcmpl-1778145400797"}}
