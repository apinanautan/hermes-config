{"type":"message","id":"5b3be2b0","parentId":"8f0b234b","timestamp":"2026-05-10T07:41:32.481Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The boss wants me to add auto-chunking to the skill. Let me update the _whisper_manager.py to handle long audio files by chunking them automatically.\n","thinkingSignature":"79db49edd61094f7ae59b862ef42e2ce23344b631228ae8a6d92560ccb07c2d8"},{"type":"toolCall","id":"call_function_joepkoc0yd8m_1","name":"write","arguments":{"content":"\"\"\"\nWhisper model manager - keeps model loaded in RAM for fast transcription.\nAuto-chunks long audio files to avoid OOM kills.\n\"\"\"\nimport os\nimport sys\n\n_MODEL_PATH = \"/home/apinan/.cache/whisper/large-v3-turbo.pt\"\n_STATE_FILE = \"/tmp/whisper_model_state.txt\"\n_CHUNK_DURATION = 10  # seconds per chunk to avoid OOM\n\n_model = None\n_model_info = None\n\ndef is_loaded():\n    \"\"\"Check if model is currently in RAM.\"\"\"\n    global _model\n    return _model is not None\n\ndef load():\n    \"\"\"Load Whisper model into RAM (int8 CPU). Returns (ok, message).\"\"\"\n    global _model, _model_info\n    if _model is not None:\n        return True, \"Whisper model already loaded in RAM (1.51 GB)\"\n\n    try:\n        from faster_whisper import WhisperModel\n        print(\"Loading Whisper large-v3-turbo into RAM...\", file=sys.stderr)\n        _model = WhisperModel(\"large-v3-turbo\", device=\"cpu\", compute_type=\"int8\", num_workers=1)\n        _model_info = {\n            \"size_gb\": os.path.getsize(_MODEL_PATH) / (1024**3),\n            \"compute\": \"int8\",\n            \"device\": \"cpu\"\n        }\n        with open(_STATE_FILE, \"w\") as f:\n            f.write(\"loaded\")\n        return True, f\"Whisper model loaded into RAM ({_model_info['size_gb']:.2f} GB, int8 CPU)\"\n    except Exception as e:\n        return False, f\"Failed to load Whisper: {e}\"\n\ndef unload():\n    \"\"\"Unload Whisper model from RAM. Returns (ok, message).\"\"\"\n    global _model, _model_info\n    if _model is None:\n        return True, \"Whisper model already unloaded\"\n\n    try:\n        del _model\n        _model = None\n        _model_info = None\n        if os.path.exists(_STATE_FILE):\n            os.remove(_STATE_FILE)\n        import gc\n        gc.collect()\n        return True, \"Whisper model unloaded from RAM\"\n    except Exception as e:\n        return False, f\"Failed to unload: {e}\"\n\ndef _get_audio_duration(wav_path):\n    \"\"\"Get duration in seconds using ffprobe.\"\"\"\n    import subprocess\n    try:\n        result = subprocess.run(\n            [\"ffprobe\", \"-v\", \"quiet\", \"-show_entries\", \"format=duration\", \"-of\", \"csv=p=0\", wav_path],\n            capture_output=True, text=True, timeout=5\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\ndef _chunk_audio(wav_path, chunk_duration=_CHUNK_DURATION):\n    \"\"\"Split audio file into chunks of chunk_duration seconds. Returns list of temp chunk paths.\"\"\"\n    duration = _get_audio_duration(wav_path)\n    if not duration or duration <= chunk_duration:\n        return [wav_path]\n\n    chunks = []\n    start = 0\n    i = 0\n    while start < duration:\n        chunk_path = f\"/tmp/wchunk_{os.getpid()}_{i}.wav\"\n        result = os.system(\n            f\"ffmpeg -i {wav_path} -ss {start} -t {chunk_duration} \"\n            f\"-ar 16000 -ac 1 -c:a pcm_s16le {chunk_path} -y 2>/dev/null\"\n        )\n        if result == 0 and os.path.exists(chunk_path):\n            chunks.append(chunk_path)\n        start += chunk_duration\n        i += 1\n    return chunks\n\ndef transcribe(wav_path):\n    \"\"\"Transcribe a WAV file. Auto-chunks if >10s. Returns (text, info).\"\"\"\n    if _model is None:\n        raise RuntimeError(\"Whisper model not loaded. Run /เปิดเสียงพูด first.\")\n\n    import subprocess\n    duration = _get_audio_duration(wav_path)\n    needs_temp = False\n\n    # Convert OGG to WAV if needed\n    if wav_path.endswith('.ogg'):\n        temp_wav = f\"/tmp/ogg2wav_{os.getpid()}.wav\"\n        result = subprocess.run(\n            [\"ffmpeg\", \"-i\", wav_path, \"-ar\", \"16000\", \"-ac\", \"1\", \"-c:a\", \"pcm_s16le\", temp_wav, \"-y\"],\n            capture_output=True, timeout=30\n        )\n        if result.returncode == 0:\n            wav_path = temp_wav\n            needs_temp = True\n\n    chunks = _chunk_audio(wav_path, _CHUNK_DURATION)\n    is_temp_input = needs_temp or (len(chunks) > 1 and wav_path != chunks[0])\n\n    try:\n        all_text = []\n        for chunk in chunks:\n            segments, info = _model.transcribe(chunk, beam_size=1, language=\"th\", vad_filter=False)\n            all_text.append(\"\".join(s.text for s in segments))\n            # Delete chunk if it's a temp file (not the original input)\n            if chunk != wav_path:\n                os.unlink(chunk)\n\n        full_text = \"\".join(all_text)\n        # info from last segment\n        return full_text, info\n    finally:\n        # Clean up temp WAV from OGG conversion\n        if needs_temp and os.path.exists(wav_path):\n            os.unlink(wav_path)\n\ndef get_status():\n    \"\"\"Return current model status.\"\"\"\n    if _model is None:\n        return {\"loaded\": False, \"size_gb\": None}\n    return {\n        \"loaded\": True,\n        \"size_gb\": os.path.getsize(_MODEL_PATH) / (1024**3),\n        \"compute\": \"int8\",\n        \"device\": \"cpu\"\n    }\n\n# Auto-load on import if state file exists\nif os.path.exists(_STATE_FILE):\n    load()","path":"/home/apinan/.openclaw/plugin-skills/voice-speech/scripts/_whisper_manager.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":422,"output":1353,"cacheRead":68672,"cacheWrite":0,"totalTokens":70447,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778398854791,"responseId":"064f6988e7bfafe0b851109eee07f8aa"}}
