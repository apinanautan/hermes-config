{"type":"message","id":"77585081","parentId":"9b7477ad","timestamp":"2026-05-10T15:58:38.243Z","message":{"role":"toolResult","toolCallId":"call_function_709j2ngbp2zc_1","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n#\n# openclaw-auto-compact.sh\n# monitors OpenClaw sessions and auto-compacts when context >= 25%\n# keeps latest session + backup + latest 3 summaries\n#\nset -euo pipefail\n\nWORKSPACE=\"/home/apinan/.openclaw/agents/main/sessions\"\nSESSION_JSON=\"$WORKSPACE/sessions.json\"\nTRASH_DIR=\"$WORKSPACE/.trash\"\nSUMMARIES_DIR=\"$WORKSPACE/.summaries\"\nLOG_FILE=\"$WORKSPACE/.compact-monitor.log\"\nKEEP_MESSAGES=30      # keep last N message entries per session\nCONTEXT_THRESHOLD=25  # compact when context >= 25%\nSUMMARY_COUNT=3       # keep latest 3 summaries\n\nmkdir -p \"$TRASH_DIR\" \"$SUMMARIES_DIR\"\n\nlog() { echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $*\" | tee -a \"$LOG_FILE\"; }\n\n# Parse jsonl for a session, returns estimated context %\nestimate_context() {\n    local session_file=\"$1\"\n    [ ! -f \"$session_file\" ] && echo \"0\" && return\n    \n    python3 -c \"\nimport json, os\n\nfile = '$session_file'\nsize = os.path.getsize(file)\n\n# rough: 1 char ~= 0.25 tokens, 200k context window\nestimated_tokens = size / 4\npct = min((estimated_tokens / 200000) * 100, 100)\nprint(f'{pct:.1f}')\n\" 2>/dev/null || echo \"0\"\n}\n\n# Parse jsonl and count message entries\ncount_messages() {\n    local session_file=\"$1\"\n    [ ! -f \"$session_file\" ] && echo \"0\" && return\n    python3 -c \"\nimport json\ncount = 0\nwith open('$session_file') as f:\n    for line in f:\n        try:\n            if json.loads(line).get('type') == 'message':\n                count += 1\n        except:\n            pass\nprint(count)\n\" 2>/dev/null || echo \"0\"\n}\n\n# Get all session keys from sessions.json\nlist_sessions() {\n    python3 -c \"\nimport json\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\nfor key in data:\n    if isinstance(data[key], dict) and 'sessionFile' in data[key]:\n        print(key)\n\" 2>/dev/null\n}\n\n# Get session file path\nget_session_file() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\nprint(data.get(key, {}).get('sessionFile', ''))\n\" \"$1\" 2>/dev/null\n}\n\n# Get last interaction time\nget_last_interaction() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\ninfo = data.get(key, {})\nprint(info.get('lastInteractionAt', 0))\n\" \"$1\" 2>/dev/null\n}\n\n# Compact a single session jsonl\ncompact_session() {\n    local session_key=\"$1\"\n    local session_file=\"$2\"\n    \n    [ ! -f \"$session_file\" ] && return\n    \n    local msg_count\n    msg_count=$(count_messages \"$session_file\")\n    # Remove any trailing whitespace/newlines\n    msg_count=$(echo \"$msg_count\" | tr -d '[:space:]')\n    \n    [ -z \"$msg_count\" ] && msg_count=0\n    \n    if [ \"$msg_count\" -le \"$KEEP_MESSAGES\" ]; then\n        return\n    fi\n    \n    # Backup\n    local backup=\"${session_file}.compact-$(date +%Y%m%d-%H%M%S)\"\n    cp \"$session_file\" \"$backup\"\n    \n    # Parse jsonl, keep header lines + last N messages using heredoc\n    python3 << PYEOF\nimport json, sys, os\n\ninput_file = '$session_file'\nkeep_messages = $KEEP_MESSAGES\n\nmessages = []\nheader = []\n\nwith open(input_file, 'r') as f:\n    for line in f:\n        try:\n            obj = json.loads(line)\n            if obj.get('type') == 'message':\n                messages.append(line)\n            else:\n                header.append(line)\n        except:\n            header.append(line)\n\nwith open(input_file + '.tmp', 'w') as f:\n    for line in header:\n        f.write(line)\n    for line in messages[-keep_messages:]:\n        f.write(line)\n\nprint(f'COMPACT: {len(messages)} -> {min(len(messages), keep_messages)} messages', flush=True)\nPYEOF\n  