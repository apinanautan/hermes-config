t all session keys from sessions.json\nlist_sessions() {\n    python3 -c \"\nimport json\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\nfor key in data:\n    if isinstance(data[key], dict) and 'sessionFile' in data[key]:\n        print(key)\n\" 2>/dev/null\n}\n\n# Get session file path\nget_session_file() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\nprint(data.get(key, {}).get('sessionFile', ''))\n\" \"$1\" 2>/dev/null\n}\n\n# Get last interaction time\nget_last_interaction() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\ninfo = data.get(key, {})\nprint(info.get('lastInteractionAt', 0))\n\" \"$1\" 2>/dev/null\n}\n\n# Compact a single session jsonl\ncompact_session() {\n    local session_key=\"$1\"\n    local session_file=\"$2\"\n    \n    [ ! -f \"$session_file\" ] && return\n    \n    local msg_count\n    msg_count=$(count_messages \"$session_file\")\n    # Remove any trailing whitespace/newlines\n    msg_count=$(echo \"$msg_count\" | tr -d '[:space:]')\n    \n    [ -z \"$msg_count\" ] && msg_count=0\n    \n    if [ \"$msg_count\" -le \"$KEEP_MESSAGES\" ]; then\n        return\n    fi\n    \n    # Backup\n    local backup=\"${session_file}.compact-$(date +%Y%m%d-%H%M%S)\"\n    cp \"$session_file\" \"$backup\"\n    \n    # Parse jsonl, keep header lines + last N messages using heredoc\n    python3 << PYEOF\nimport json, sys, os\n\ninput_file = '$session_file'\nkeep_messages = $KEEP_MESSAGES\n\nmessages = []\nheader = []\n\nwith open(input_file, 'r') as f:\n    for line in f:\n        try:\n            obj = json.loads(line)\n            if obj.get('type') == 'message':\n                messages.append(line)\n            else:\n                header.append(line)\n        except:\n            header.append(line)\n\nwith open(input_file + '.tmp', 'w') as f:\n    for line in header:\n        f.write(line)\n    for line in messages[-keep_messages:]:\n        f.write(line)\n\nprint(f'COMPACT: {len(messages)} -> {min(len(messages), keep_messages)} messages', flush=True)\nPYEOF\n    \n    if [ -f \"${session_file}.tmp\" ]; then\n        mv \"${session_file}.tmp\" \"$session_file\"\n        log \"COMPACTED: $session_key ($msg_count messages, backup: $backup)\"\n    fi\n}\n\n# Create text summary of session\ncreate_summary() {\n    local session_key=\"$1\"\n    local session_file=\"$2\"\n    local summary_file=\"$SUMMARIES_DIR/${session_key}.summary.txt\"\n    \n    python3 << PYEOF\nimport json, os\nfrom datetime import datetime\n\nsession_key = '$session_key'\nsession_file = '$session_file'\nsummary_file = '$summary_file'\n\ntry:\n    with open(session_file, 'r') as f:\n        lines = f.readlines()\n    \n    messages = []\n    for line in lines:\n        try:\n            obj = json.loads(line)\n            if obj.get('type') == 'message':\n                msg = obj.get('message', {})\n                role = msg.get('role', '')\n                content_list = msg.get('content', [])\n                content = ''\n                for c in content_list:\n                    if isinstance(c, dict) and c.get('type') == 'text':\n                        content = c.get('text', '')[:200]\n                        break\n                if content:\n                    messages.append((role, content[:100]))\n        except:\n            pass\n    \n    with open(summary_file, 'w') as f:\n        f.write(f'Session: {session_key}\\n')\n        f.write(f'File: {session_file}\\n')\n        f.write(f'Size: {os.path.getsize(session_file)} bytes\\n')\n        f.write(f'Total messages: {len(messages)}\\n')\n        if messages:\n            f.write(f'First user: {messages[0][1]}\\n')\n            f.write(f'Last user: {messages[-1][1]}\\n')\n            if len(messages) > 1:\n                f.write(f'Last assistant: {messages[-2][1]}\\n')\n        f.write(f'Summary created: {datet