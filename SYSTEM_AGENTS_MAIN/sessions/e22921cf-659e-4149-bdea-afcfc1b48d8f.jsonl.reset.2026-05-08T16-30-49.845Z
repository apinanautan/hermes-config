{"type":"custom_message","customType":"openclaw.runtime-context","content":"Conversation info (untrusted metadata):\n```json\n{\n  \"chat_id\": \"telegram:1060942816\",\n  \"message_id\": \"7487\",\n  \"sender_id\": \"1060942816\",\n  \"sender\": \"▫️\",\n  \"timestamp\": \"Fri 2026-05-08 16:37 GMT+7\"\n}\n```\n\nSender (untrusted metadata):\n```json\n{\n  \"label\": \"▫️ (1060942816)\",\n  \"id\": \"1060942816\",\n  \"name\": \"▫️\",\n  \"username\": \"robberzaz\"\n}\n```","display":false,"details":{"source":"openclaw-runtime-context"},"id":"ea0bb714","parentId":"42ec4c43","timestamp":"2026-05-08T09:38:00.009Z"}
{"type":"message","id":"2f2aa1e7","parentId":"ea0bb714","timestamp":"2026-05-08T09:38:15.138Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"เจ้านายต้องการให้สร้าง skill ufo-aiface ให้ OpenClaw โดยดูจากไฟล์ที่มีอยู่ใน `C:\\Users\\Apinan\\Desktop\\Work Auto\\ufo-aiface\\`\n\nให้ผมอ่านไฟล์หลักๆ ให้หมดก่อนแล้วสร้าง SKILL.md จากนั้น\n","thinkingSignature":"6f7d415455aad1832d3db508e7db9b42ae93feefe9eb92c285432e9d18747a46"},{"type":"toolCall","id":"call_function_x4qfsz9b5lwg_1","name":"exec","arguments":{"command":"cat \"/mnt/c/Users/Apinan/Desktop/Work Auto/ufo-aiface/gpt_aiface_image.py\" 2>/dev/null","timeout":10}},{"type":"toolCall","id":"call_function_x4qfsz9b5lwg_2","name":"exec","arguments":{"command":"cat \"/mnt/c/Users/Apinan/Desktop/Work Auto/ufo-aiface/run_aiface.ps1\" 2>/dev/null && echo \"---\" && cat \"/mnt/c/Users/Apinan/Desktop/Work Auto/ufo-aiface/run_aiface.bat\" 2>/dev/null","timeout":5}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":5415,"output":282,"cacheRead":91584,"cacheWrite":0,"totalTokens":97281,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778233080009,"responseId":"064ce1fae0e6cfb5b6d8f72385574940"}}
{"type":"message","id":"5de3a0e3","parentId":"2f2aa1e7","timestamp":"2026-05-08T09:38:15.222Z","message":{"role":"toolResult","toolCallId":"call_function_x4qfsz9b5lwg_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"AiFace — ChatGPT Custom GPT image generator for human faces.\n\nControls Chrome through CDP/Playwright only: no OS mouse movement, no real keyboard,\nno UFO clicking. Designed for the user's logged-in Windows Chrome profile.\n\"\"\"\n\nimport argparse\nimport asyncio\nimport base64\nimport json\nimport os\nimport re\nimport shutil\nimport sys\nimport time\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Optional, Tuple\n\nfrom playwright.async_api import async_playwright, TimeoutError as PlaywrightTimeoutError\n\nGPT_URL = \"https://chatgpt.com/g/g-699b39eeedc4819180aeb6ad24c464d9\"\nDEFAULT_CDP = \"http://127.0.0.1:9223\"\nDEFAULT_OUT_DIR = r\"C:\\Users\\Apinan\\Desktop\\Work Auto\\รูป AiFace\" if os.name == \"nt\" else \"/mnt/c/Users/Apinan/Desktop/Work Auto/รูป AiFace\"\nDEFAULT_RUNTIME_DIR = r\"C:\\Users\\Apinan\\Desktop\\Work Auto\\ufo-aiface\\runtime 🏃💨\" if os.name == \"nt\" else \"/mnt/c/Users/Apinan/Desktop/Work Auto/ufo-aiface/runtime 🏃💨\"\nDEFAULT_OLLAMA_URL = \"http://127.0.0.1:11434\"\nDEFAULT_VISION_MODEL = \"moondream:latest\"\nDEFAULT_TEXT_JUDGE_MODEL = \"qwen2.5:3b\"\n\n\ndef safe_name(text: str, max_len: int = 36) -> str:\n    text = re.sub(r\"[^0-9A-Za-zก-๙_-]+\", \"_\", text).strip(\"_\")\n    return (text[:max_len] or \"aiface_image\")\n\n\ndef reset_runtime_dir() -> Path:\n    runtime_dir = Path(DEFAULT_RUNTIME_DIR)\n    if runtime_dir.exists():\n        shutil.rmtree(runtime_dir, ignore_errors=True)\n    runtime_dir.mkdir(parents=True, exist_ok=True)\n    return runtime_dir\n\n\ndef cleanup_runtime_dir(runtime_dir: Optional[Path]):\n    if not runtime_dir:\n        return\n    try:\n        if runtime_dir.exists():\n            shutil.rmtree(runtime_dir, ignore_errors=True)\n    except Exception:\n        pass\n\n\nasync def find_or_create_gpt_page(context):\n    for pg in context.pages:\n        if \"chatgpt.com/g/g-699b39eeedc4819180aeb6ad24c464d9\" in (pg.url or \"\"):\n            return pg\n    pg = await context.new_page()\n    await pg.goto(GPT_URL, wait_until=\"domcontentloaded\", timeout=60000)\n    return pg\n\n\nasync def set_prompt_without_real_keyboard(page, prompt: str):\n    box = page.locator(\"#prompt-textarea\").last\n    await box.wait_for(state=\"visible\", timeout=30000)\n\n    await box.evaluate(\n        \"\"\"(el, text) => {\n            el.focus();\n            if (el.tagName === 'TEXTAREA' || el.tagName === 'INPUT') {\n                el.value = text;\n            } else {\n                el.textContent = text;\n            }\n            el.dispatchEvent(new InputEvent('input', {bubbles: true, inputType: 'insertText', data: text}));\n            el.dispatchEvent(new Event('change', {bubbles: true}));\n        }\"\"\",\n        prompt,\n    )\n\n    send_candidates = [\n        \"button[data-testid='send-button']\",\n        \"button[aria-label*='Send']\",\n        \"button[aria-label*='ส่ง']\",\n    ]\n    for sel in send_candidates:\n        btn = page.locator(sel).last\n        try:\n            if await btn.count() and await btn.is_enabled(timeout=1500):\n                await btn.click(timeout=5000)\n                return\n        except Exception:\n            pass\n\n    await box.press(\"Enter\")\n\n\nasync def collect_large_images(page):\n    return await page.evaluate(\n        \"\"\"() => Array.from(document.images).map((img, idx) => ({\n            idx,\n            src: img.currentSrc || img.src || '',\n            alt: img.alt || '',\n            w: img.naturalWidth || img.width || 0,\n            h: img.naturalHeight || img.height || 0\n        })).filter(x => x.src && x.w >= 200 && x.h >= 200)\n          .sort((a,b)=>(b.w*b.h)-(a.w*a.h))\"\"\"\n    )\n\n\nasync def fetch_image_bytes_in_browser(page, url: str):\n    return await page.evaluate(\n        \"\"\"async (url) => {\n            const r = await fetch(url, { credentials: 'include' });\n            const ct = r.headers.get('content-type') || '';\n            const ab = await r.arrayBuffer();\n            const bytes = new Uint8Array(ab);\n            let bin = '';\n            const chunk = 0x8000;\n            for (let i = 0; i < bytes.length; i += chunk) {\n                bin += String.fromCharCode.apply(null, bytes.subarray(i, i + chunk));\n            }\n            return { ok: r.ok, status: r.status, ct, b64: btoa(bin), size: bytes.length };\n        }\"\"\",\n        url,\n    )\n\n\ndef technical_image_gate(res: dict, img: dict, require_full: bool = True) -> Tuple[bool, str]:\n    src = img.get(\"src\", \"\") or \"\"\n    ct = (res.get(\"ct\") or \"\").lower()\n    size = int(res.get(\"size\") or 0)\n    w = int(img.get(\"w\") or 0)\n    h = int(img.get(\"h\") or 0)\n\n    if \"backend-api/estuary/content\" not in src:\n        return False, \"ไม่ใช่ ChatGPT estuary content URL\"\n    if not res.get(\"ok\"):\n        return False, f\"fetch ไม่สำเร็จ status={res.get('status')}\"\n    if \"image\" not in ct:\n        return False, f\"content-type ไม่ใช่รูป: {ct}\"\n    if require_full:\n        if w < 1000 or h < 700:\n            return False, f\"resolution ต่ำเกินไป/น่าจะ thumbnail: {w}x{h}\"\n        if size < 300_000:\n            return False, f\"ไฟล์เล็กเกินไป/น่าจะ preview: {size} bytes\"\n    else:\n        if w < 400 or h < 400:\n            return False, f\"resolution ต่ำเกินไป: {w}x{h}\"\n        if size < 80_000:\n            return False, f\"ไฟล์เล็กเกินไป: {size} bytes\"\n    return True, \"ผ่าน technical gate\"\n\n\ndef extract_json_object(text: str) -> dict:\n    try:\n        return json.loads(text)\n    except Exception:\n        pass\n    m = re.search(r\"\\{.*\\}\", text, re.S)\n    if not m:\n        raise ValueError(f\"ไม่มี JSON ใน vision response: {text[:300]}\")\n    return json.loads(m.group(0))\n\n\ndef ollama_generate(payload: dict, ollama_url: str = DEFAULT_OLLAMA_URL, timeout: int = 90) -> str:\n    data = json.dumps(payload).encode(\"utf-8\")\n    req = urllib.request.Request(\n        ollama_url.rstrip(\"/\") + \"/api/generate\",\n        data=data,\n        headers={\"Content-Type\": \"application/json\"},\n        method=\"POST\",\n    )\n    with urllib.request.urlopen(req, timeout=timeout) as r:\n        raw = r.read().decode(\"utf-8\", \"replace\")\n    return json.loads(raw).get(\"response\", \"\")\n\n\ndef text_judge_match(prompt: str, caption: str, model: str = DEFAULT_TEXT_JUDGE_MODEL, min_confidence: float = 0.75) -> Tuple[bool, dict]:\n    judge_prompt = f\"\"\"\nYou are a strict verifier. Decide whether the IMAGE CAPTION matches the USER REQUEST.\n\nUSER REQUEST:\n{prompt}\n\nIMAGE CAPTION FROM MOONDREAM:\n{caption}\n\nReturn ONLY JSON:\n{{\"matches_prompt\":true/false,\"confidence\":0.0-1.0,\"detected_subject\":\"...\",\"reason\":\"...\"}}\n\nJudge the CORE SUBJECT first. If the caption clearly shows the requested main objects, set matches_prompt=true even if the caption does not literally say words like \"3D face\", \"realistic\", or \"human face\". Only set false when the main subject is missing or clearly wrong. Style constraints such as clean background/no text/no logo should reduce confidence only when clearly violated.\n\"\"\".strip()\n    try:\n        text = ollama_generate({\n            \"model\": model,\n            \"prompt\": judge_prompt,\n            \"stream\": False,\n            \"options\": {\"temperature\": 0},\n        }, timeout=90)\n        report = extract_json_object(text)\n        report[\"raw_judge_response\"] = text\n        confidence = float(report.get(\"confidence\") or 0.0)\n        ok = bool(report.get(\"matches_prompt\")) and confidence >= min_confidence\n        return ok, report\n    except Exception as e:\n        return False, {\"matches_prompt\": False, \"confidence\": 0.0, \"detected_subject\": \"\", \"reason\": f\"Text judge error: {e}\"}\n\n\ndef moondream_verify_image_b64(\n    image_b64: str,\n    prompt: str,\n    model: str = DEFAULT_VISION_MODEL,\n    ollama_url: str = DEFAULT_OLLAMA_URL,\n    min_confidence: float = 0.75,\n) -> Tuple[bool, dict]:\n    try:\n        caption = ollama_generate({\n            \"model\": model,\n            \"prompt\": \"Describe this image in detail in English. Do not repeat the user's prompt. Describe only what is visible.\",\n            \"images\": [image_b64],\n            \"stream\": False,\n            \"options\": {\"temperature\": 0},\n        }, ollama_url=ollama_url, timeout=90).strip()\n        if not caption:\n            return False, {\"matches_prompt\": False, \"confidence\": 0.0, \"detected_subject\": \"\", \"reason\": \"Moondream returned empty caption\"}\n        ok, report = text_judge_match(prompt, caption, min_confidence=min_confidence)\n        report[\"moondream_caption\"] = caption\n        report[\"vision_model\"] = model\n        report[\"text_judge_model\"] = DEFAULT_TEXT_JUDGE_MODEL\n        return ok, report\n    except Exception as e:\n        return False, {\"matches_prompt\": False, \"confidence\": 0.0, \"detected_subject\": \"\", \"reason\": f\"Moondream verify error: {e}\"}\n\n\nasync def safe_disconnect(browser):\n    try:\n        fn = getattr(browser, \"disconnect\", None)\n        if fn:\n            await fn()\n    except Exception:\n        pass\n\n\nasync def generate(\n    prompt: str,\n    output: Optional[str],\n    cdp_url: str,\n    timeout_sec: int,\n    require_full: bool = True,\n    vision_model: str = DEFAULT_VISION_MODEL,\n    min_confidence: float = 0.75,\n):\n    out_dir = Path(DEFAULT_OUT_DIR)\n    out_dir.mkdir(parents=True, exist_ok=True)\n    if output:\n        output_path = Path(output)\n    else:\n        stamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n        output_path = out_dir / f\"aiface_{stamp}_{safe_name(prompt)}.png\"\n\n    runtime_dir = reset_runtime_dir()\n\n    async with async_playwright() as p:\n        browser = await p.chromium.connect_over_cdp(cdp_url, timeout=20000)\n        context = browser.contexts[0]\n        page = await find_or_create_gpt_page(context)\n        await page.wait_for_load_state(\"domcontentloaded\", timeout=60000)\n\n        before = {x.get(\"src\") for x in await collect_large_images(page)}\n        await set_prompt_without_real_keyboard(page, prompt)\n\n        deadline = time.time() + timeout_sec\n        last_seen = []\n        while time.time() < deadline:\n            await page.wait_for_timeout(2500)\n            imgs = await collect_large_images(page)\n            last_seen = imgs[:3]\n            candidates = [x for x in imgs if x.get(\"src\") and x.get(\"src\") not in before]\n            candidates.sort(key=lambda x: (\"backend-api/estuary/content\" in x[\"src\"], x[\"w\"] * x[\"h\"]), reverse=True)\n            for img in candidates:\n                src = img[\"src\"]\n                try:\n                    res = await fetch_image_bytes_in_browser(page, src)\n                    tech_ok, tech_reason = technical_image_gate(res, img, require_full=require_full)\n                    if not tech_ok:\n                        print(f\"REJECT_TECH {tech_reason} src_w={img.get('w')} src_h={img.get('h')} ct={res.get('ct')} size={res.get('size')}\", file=sys.stderr)\n                        continue\n\n                    vision_ok, vision_report = await asyncio.to_thread(\n                        moondream_verify_image_b64,\n                        res[\"b64\"],\n                        prompt,\n                        vision_model,\n                        DEFAULT_OLLAMA_URL,\n                        min_confidence,\n                    )\n                    report_path = runtime_dir / f\"{output_path.stem}.verify.json\"\n                    report_path.write_text(\n                        json.dumps({\n                            \"technical_gate\": tech_reason,\n                            \"image\": img,\n                            \"content_type\": res.get(\"ct\"),\n                            \"size\": res.get(\"size\"),\n                            \"vision_model\": vision_model,\n                            \"min_confidence\": min_confidence,\n                            \"vision_ok\": vision_ok,\n                            \"vision_report\": vision_report,\n                        }, ensure_ascii=False, indent=2),\n                        encoding=\"utf-8\",\n                    )\n                    if not vision_ok:\n                        print(f\"REJECT_VISION {vision_report}\", file=sys.stderr)\n                        # แม้ vision ไม่ผ่าน ก็เซฟรูปไว้ก่อน\n                        output_path.write_bytes(base64.b64decode(res[\"b64\"]))\n                        cleanup_runtime_dir(runtime_dir)\n                        await safe_disconnect(browser)\n                        return str(output_path), res, img, vision_report\n\n                    output_path.write_bytes(base64.b64decode(res[\"b64\"]))\n                    cleanup_runtime_dir(runtime_dir)\n                    await safe_disconnect(browser)\n                    return str(output_path), res, img, vision_report\n                except Exception as e:\n                    print(f\"REJECT_ERROR {e}\", file=sys.stderr)\n                    continue\n\n        await safe_disconnect(browser)\n        cleanup_runtime_dir(runtime_dir)\n        raise TimeoutError(f\"No downloadable generated image found. Last images: {last_seen}\")\n\n\nasync def main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"prompt\", help=\"Thai prompt to send to ChatGPT GPT\")\n    ap.add_argument(\"--output\", \"-o\", default=None, help=\"Output PNG path\")\n    ap.add_argument(\"--cdp\", default=DEFAULT_CDP, help=\"Chrome CDP endpoint\")\n    ap.add_argument(\"--timeout\", type=int, default=150, help=\"Max seconds to wait\")\n    ap.add_argument(\"--vision-model\", default=DEFAULT_VISION_MODEL, help=\"Ollama vision model for semantic verification\")\n    ap.add_argument(\"--min-confidence\", type=float, default=0.75, help=\"Minimum Moondream confidence before accepting/sending\")\n    ap.add_argument(\"--allow-preview\", action=\"store_true\", help=\"Allow lower-res preview images (normally off)\")\n    args = ap.parse_args()\n\n    path, res, img, vision_report = await generate(\n        args.prompt,\n        args.output,\n        args.cdp,\n        args.timeout,\n        require_full=not args.allow_preview,\n        vision_model=args.vision_model,\n        min_confidence=args.min_confidence,\n    )\n    print(path)\n    print(f\"content_type={res.get('ct')} size={res.get('size')} source_w={img.get('w')} source_h={img.get('h')}\")\n    print(f\"vision_model={args.vision_model} confidence={vision_report.get('confidence')} subject={vision_report.get('detected_subject')} reason={vision_report.get('reason')}\")\n\n\nif __name__ == \"__main__\":\n    try:\n        asyncio.run(main())\n    except Exception as e:\n        print(f\"ERROR: {e}\", file=sys.stderr)\n        sys.exit(1)"}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":8193,"originalDetailKeys":["status","exitCode","durationMs","aggregated","cwd"],"status":"completed","cwd":"/home/apinan/.openclaw/workspace","exitCode":0},"isError":false,"timestamp":1778233095221}}
