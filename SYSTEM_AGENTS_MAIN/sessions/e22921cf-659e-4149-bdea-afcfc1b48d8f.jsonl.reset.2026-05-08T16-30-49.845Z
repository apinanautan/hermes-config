{"type":"message","id":"620c196a","parentId":"a193c56e","timestamp":"2026-05-08T11:52:49.426Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, now let me create the Universal Agent Bridge script for OpenClaw workspace.\n","thinkingSignature":"3e1185c94fef38724b1d91569971a476c1250550494fa26fb576ffcdf38eb355"},{"type":"toolCall","id":"call_function_w0lzo2fnyjga_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nUniversal Agent Bridge — Model-Agnostic Pipeline for OpenClaw\n==============================================================\n\nมันคือ \"สะพานเชื่อม\" ระหว่าง:\n  - Local LLM (Ollama) = ล่าม + วิศวกร\n  - Cloud LLM (API) = สมองใหญ่ผู้วิเคราะห์\n  - MCP Tools = มือที่ลงมือทำจริง\n\nโครงสร้าง 4 ด่าน:\n  [Preprocessor] → [Router] → [Executor] → [Summarizer]\n\nConfig: ใช้ JSON ง่ายๆ ไม่ต้องติดตั้งอะไรเพิ่ม\n\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\nfrom pathlib import Path\nfrom typing import Optional\n\n# ============================================================================\n# SECTION 1: CONFIGURATION\n# ============================================================================\n\"\"\"\nConfig เก็บไว้ที่เดียว ง่ายต่อการสลับโมเดล\n- LOCAL_MODEL: โมเดล local ที่รันผ่าน Ollama\n- CLOUD_*: Base URL และโมเดลสำหรับ Cloud API\n\"\"\"\n\nDEFAULT_CONFIG = {\n    \"local\": {\n        \"base_url\": \"http://127.0.0.1:11434/v1\",\n        \"model\": \"hermes3:8b\",  # Default: Hermes 3 local\n        \"api_key\": \"ollama\",    # Ollama ไม่ต้อง key\n    },\n    \"cloud\": {\n        \"base_url\": \"https://ollama-pay.thaigqsoft.com/api/v1\",\n        \"model\": \"minimax/MiniMax-M2.7\",\n        \"api_key_env\": \"OLLAMA_PAY_API_KEY\",  # ดึงจาก env\n    },\n    \"router\": {\n        \"max_local_tokens\": 500,  # ถ้า input > 500 tokens ให้ local สรุปก่อน\n        \"history_limit\": 10,       # เก็บ history สุดท้ายกี่ turn\n    },\n    \"executor\": {\n        \"preferred\": \"local\",  # ให้ local เป็นคนเลือก tool ก่อน\n    }\n}\n\ndef load_config(config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\") -> dict:\n    \"\"\"โหลด config จากไฟล์ ถ้าไม่มีใช้ default\"\"\"\n    p = Path(config_path).expanduser()\n    if p.exists():\n        with open(p, \"r\", encoding=\"utf-8\") as f:\n            user = json.load(f)\n            # Merge: user override default\n            result = DEFAULT_CONFIG.copy()\n            for key in result:\n                if key in user:\n                    result[key] = {**result[key], **user[key]}\n            return result\n    return DEFAULT_CONFIG\n\n# ============================================================================\n# SECTION 2: STATEFUL HISTORY (ประหยัด token)\n# ============================================================================\n\"\"\"\nเก็บ history ไว้ใน memory ของ process นี้\nถ้าต้องการ persistent ใช้ JSON file หรือ SQLite ต่อได้\n\"\"\"\n\nclass ConversationHistory:\n    \"\"\"เก็บ history สั้นๆ ประหยัด token\"\"\"\n    \n    def __init__(self, limit: int = 10):\n        self.limit = limit\n        self.turns: list[dict] = []\n    \n    def add(self, role: str, content: str, meta: str = \"\"):\n        \"\"\"เพิ่ม turn ใหม่เข้า history\"\"\"\n        self.turns.append({\n            \"role\": role,\n            \"content\": content,\n            \"meta\": meta,\n            \"ts\": time.time()\n        })\n        # Trim ให้ไม่เกิน limit\n        if len(self.turns) > self.limit:\n            self.turns = self.turns[-self.limit:]\n    \n    def get_context(self, max_chars: int = 2000) -> str:\n        \"\"\"ดึง context สำหรับส่งให้ LLM\"\"\"\n        lines = []\n        for turn in self.turns[-self.limit:]:\n            lines.append(f\"[{turn['role']}] {turn['content']}\")\n        \n        context = \"\\n\".join(lines)\n        # Trim ถ้ายาวเกิน\n        if len(context) > max_chars:\n            context = context[-max_chars:]\n        return context\n    \n    def clear(self):\n        self.turns = []\n    \n    def summary(self) -> str:\n        return f\"History: {len(self.turns)} turns\"\n\n\n# ============================================================================\n# SECTION 3: PREPROCESSOR (Local LLM = ล่าม)\n# ============================================================================\n\"\"\"\nPreprocessor ทำหน้าที่:\n1. รับ input ใดๆ (เช่น ภาษาไทย)\n2. ส่งไปให้ Local LLM สรุปเป็น English\n3. ถ้า input สั้น (< max_local_tokens) ข้ามไปได้เลย\n\"\"\"\n\ndef count_tokens_approx(text: str) -> int:\n    \"\"\"ประมาณ token count แบบหยาบๆ (1 token ≈ 4 chars)\"\"\"\n    return len(text) // 4\n\ndef call_llm(\n    base_url: str,\n    model: str,\n    prompt: str,\n    api_key: str = \"ollama\",\n    system: str = \"\",\n    history: str = \"\",\n    timeout: int = 120\n) -> str:\n    \"\"\"\n    Generic OpenAI-compatible API call\n    ใช้ได้กับทุก provider (Ollama, Ollama-Pay, OpenAI, etc.)\n    \"\"\"\n    messages = []\n    if system:\n        messages.append({\"role\": \"system\", \"content\": system})\n    if history:\n        # ตัด history เก่าออกถ้ายาวเกิน\n        if len(history) > 3000:\n            history = history[-3000:]\n        messages.append({\"role\": \"assistant\", \"content\": f\"[Context]\\n{history}\"})\n    messages.append({\"role\": \"user\", \"content\": prompt})\n    \n    payload = {\n        \"model\": model,\n        \"messages\": messages,\n        \"temperature\": 0.3,  # ต่ำ = deterministic, เหมาะกับ summarize\n    }\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {api_key}\"\n    }\n    \n    req = urllib.request.Request(\n        f\"{base_url.rstrip('/')}/chat/completions\",\n        data=json.dumps(payload).encode(\"utf-8\"),\n        headers=headers,\n        method=\"POST\"\n    )\n    \n    try:\n        with urllib.request.urlopen(req, timeout=timeout) as resp:\n            data = json.loads(resp.read().decode(\"utf-8\"))\n            return data[\"choices\"][0][\"message\"][\"content\"]\n    except urllib.error.HTTPError as e:\n        return f\"[HTTP ERROR {e.code}]: {e.read().decode()}\"\n    except Exception as e:\n        return f\"[ERROR]: {str(e)}\"\n\n\nclass Preprocessor:\n    \"\"\"Local LLM = ล่ามแปลง input เป็น English\"\"\"\n    \n    SYSTEM_PROMPT = \"\"\"You are a Thai-to-English translator. \nTranslate the user's Thai input to English concisely.\nKeep technical terms in English.\nIf input is already in English, just return it as-is.\nDo NOT add explanations. Just translate.\"\"\"\n\n    def __init__(self, config: dict):\n        self.config = config[\"local\"]\n        self.base_url = self.config[\"base_url\"]\n        self.model = self.config[\"model\"]\n        self.api_key = self.config[\"api_key\"]\n    \n    def translate(self, thai_input: str, threshold: int = 500) -> tuple[str, bool]:\n        \"\"\"\n        แปลงานไทยเป็นอังกฤษ\n        Returns: (english_text, was_summarized)\n        \"\"\"\n        token_count = count_tokens_approx(thai_input)\n        \n        # ถ้าสั้นพอ ใช้ local summarizer\n        if token_count > threshold:\n            # Local LLM เป็นคนสรุป (force offload)\n            english = call_llm(\n                self.base_url, self.model,\n                f\"Translate to English (concise):\\n{thai_input}\",\n                api_key=self.api_key,\n                system=self.SYSTEM_PROMPT,\n                timeout=90\n            )\n            return english, True\n        else:\n            # สั้นมาก ข้าม local ส่งไป cloud เลย\n            return thai_input, False\n\n    def summarize_long(self, text: str, max_tokens: int = 150) -> str:\n        \"\"\"สรุปข้อความยาวให้กระชับ (ใช้ Local LLM)\"\"\"\n        prompt = f\"\"\"Summarize the following text in no more than {max_tokens} tokens.\nFocus on: intent, tools needed, files involved.\n\nText:\n{text}\n\nSummary:\"\"\"\n        return call_llm(\n            self.base_url, self.model,\n            prompt,\n            api_key=self.api_key,\n            system=\"You are a summarizer. Be concise.\",\n            timeout=90\n        )\n\n    def select_tool(self, task: str, available_tools: list[str]) -> str:\n        \"\"\"Local LLM เลือก tool ที่เหมาะสม\"\"\"\n        if not available_tools:\n            return \"none\"\n        \n        tools_str = \", \".join(available_tools)\n        prompt = f\"\"\"Task: {task}\nAvailable tools: {tools_str}\n\nSelect the most appropriate tool. Reply with ONLY the tool name, nothing else.\"\"\"\n\n        result = call_llm(\n            self.base_url, self.model,\n            prompt,\n            api_key=self.api_key,\n            system=\"You are a tool selector. Be concise. Reply with single tool name.\",\n            timeout=30\n        )\n        return result.strip().lower()\n\n\n# ============================================================================\n# SECTION 4: ROUTER (ส่งต่อไป Cloud)\n# ============================================================================\n\"\"\"\nRouter ทำหน้าที่:\n1. รับ English summary จาก Preprocessor\n2. เติม history context\n3. ส่งไป Cloud LLM (ผู้วิเคราะห์หลัก)\n\"\"\"\n\nclass Router:\n    \"\"\"ส่ง English summary ไป Cloud LLM\"\"\"\n    \n    def __init__(self, config: dict, history: ConversationHistory):\n        self.config = config[\"cloud\"]\n        self.base_url = self.config[\"base_url\"]\n        self.model = self.config[\"model\"]\n        self.api_key = os.environ.get(self.config[\"api_key_env\"], \"dummy\")\n        self.history = history\n    \n    def send_to_cloud(self, english_input: str, system: str = \"\") -> str:\n        \"\"\"\n        ส่งไป Cloud แล้วรอคำตอบ\n        Cloud จะ return \"Action Commands\" หรือ คำตอบตรงๆ\n        \"\"\"\n        history_context = self.history.get_context()\n        \n        full_prompt = f\"\"\"[User Input - English]\n{english_input}\n\n{'[Previous Context]\\n' + history_context if history_context else ''}\n\nReply with:\n1. Analysis (brief)\n2. Action Commands (if tool execution needed)\n3. Final Answer (if no tool needed)\nFormat clearly.\"\"\"\n        \n        return call_llm(\n            self.base_url, self.model,\n            full_prompt,\n            api_key=self.api_key,\n            system=system or self._default_system(),\n            timeout=180\n        )\n    \n    def _default_system(self) -> str:\n        return \"\"\"You are a helpful AI assistant.\nWhen a task requires tools, respond with clear action commands.\nWhen answering directly, be concise.\"\"\"\n\n\n# ============================================================================\n# SECTION 5: EXECUTOR (Local ลงมือทำ)\n# ============================================================================\n\"\"\"\nExecutor ทำหน้าที่:\n1. รับ Action Commands จาก Cloud\n2. ให้ Local LLM ตีความ + เลือก MCP/Terminal\n3. รันงานจริงในเครื่อง\n\"\"\"\n\nMCP_TOOLS = [\n    \"filesystem\",      # อ่าน/เขียนไฟล์\n    \"ollama\",          # รัน local LLM\n    \"socraticode\",     # วิเคราะห์โค้ด\n    \"puppeteer\",       # browser automation\n    \"sequential-thinking\",  # คิดทีละขั้น\n]\n\nTERMINAL_TOOLS = [\"bash\", \"python3\", \"node\"]\n\n\nclass Executor:\n    \"\"\"Local LLM เลือกและรัน tool\"\"\"\n    \n    def __init__(self, config: dict, preprocessor: Preprocessor):\n        self.config = config[\"executor\"]\n        self.local = config[\"local\"]\n        self.preprocessor = preprocessor\n    \n    def parse_commands(self, cloud_response: str) -> list[str]:\n        \"\"\"\n        Parse Action Commands ออกจาก cloud response\n        รองรับหลาย format:\n        - \"Action: read_file /path/to/file\"\n        - \"[TOOL] filesystem: read /path\"\n        - หรือแค่คำอธิบายธรรมดา\n        \"\"\"\n        commands = []\n        lines = cloud_response.split(\"\\n\")\n        for line in lines:\n            line = line.strip()\n            if not line:\n                continue\n            # จับ command lines\n            if any(line.startswith(p) for p in [\"Action:\", \"Tool:\", \"[\", \"- \", \"• \"]):\n                commands.append(line)\n        return commands\n    \n    def plan_execution(self, cloud_response: str) -> dict:\n        \"\"\"\n        Local LLM วางแผน execution\n        Returns: {tool: str, action: str, params: dict}\n        \"\"\"\n        available = MCP_TOOLS + TERMINAL_TOOLS\n        prompt = f\"\"\"Analyze this Cloud LLM response and plan execution.\n\nResponse:\n{cloud_response}\n\nAvailable tools:\n- MCP: {', '.join(MCP_TOOLS)}\n- Terminal: {', '.join(TERMINAL_TOOLS)}\n\nIf tool execution is needed, specify:\n- tool: which tool to use\n- action: what to do\n- params: relevant parameters (file paths, etc.)\n\nIf no tool needed, reply \"NO_TOOL_NEEDED\".\"\"\"\n        \n        result = call_llm(\n            self.local[\"base_url\"],\n            self.local[\"model\"],\n            prompt,\n            api_key=self.local[\"api_key\"],\n            system=\"You are an execution planner. Be precise.\",\n            timeout=60\n        )\n        \n        if \"NO_TOOL\" in result.upper():\n            return {\"needs_tool\": False}\n        \n        # Simple parsing\n        return {\n            \"needs_tool\": True,\n            \"raw_plan\": result,\n            \"tool\": self.preprocessor.select_tool(cloud_response, available)\n        }\n\n\n# ============================================================================\n# SECTION 6: MAIN BRIDGE CLASS\n# ============================================================================\n\nclass UniversalAgentBridge:\n    \"\"\"\n    สะพานเชื่อม Universal Agent Bridge\n    \n    ใช้งานง่าย:\n        bridge = UniversalAgentBridge()\n        result = bridge.run(\"คำสั่งภาษาไทย\")\n        print(result)\n    \"\"\"\n    \n    def __init__(self, config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\"):\n        self.config = load_config(config_path)\n        self.history = ConversationHistory(limit=self.config[\"router\"][\"history_limit\"])\n        self.preprocessor = Preprocessor(self.config)\n        self.router = Router(self.config, self.history)\n        self.executor = Executor(self.config, self.preprocessor)\n    \n    def run(self, user_input: str, verbose: bool = False) -> dict:\n        \"\"\"\n        Run full pipeline:\n        1. Preprocess (Local LLM)\n        2. Route to Cloud\n        3. Execute locally if needed\n        \n        Returns dict with:\n        - english_input\n        - cloud_response\n        - execution_result\n        - final_answer\n        \"\"\"\n        result = {\n            \"english_input\": \"\",\n            \"was_summarized\": False,\n            \"cloud_response\": \"\",\n            \"execution_needed\": False,\n            \"execution_result\": \"\",\n            \"final_answer\": \"\"\n        }\n        \n        # === Step 1: Preprocessor ===\n        if verbose:\n            print(\"[1/4] Preprocessing...\")\n        \n        english_input, was_summarized = self.preprocessor.translate(\n            user_input,\n            threshold=self.config[\"router\"][\"max_local_tokens\"]\n        )\n        result[\"english_input\"] = english_input\n        result[\"was_summarized\"] = was_summarized\n        \n        if verbose:\n            print(f\"   → English: {english_input[:100]}...\")\n            print(f\"   → Summarized: {was_summarized}\")\n        \n        # === Step 2: Router (Cloud) ===\n        if verbose:\n            print(\"[2/4] Sending to Cloud...\")\n        \n        cloud_response = self.router.send_to_cloud(english_input)\n        result[\"cloud_response\"] = cloud_response\n        \n        if verbose:\n            print(f\"   → Cloud responded ({len(cloud_response)} chars)\")\n        \n        # === Step 3: Update History ===\n        self.history.add(\"user\", user_input[:500])  # Trim long input\n        self.history.add(\"assistant\", cloud_response[:500])  # Trim long response\n        \n        # === Step 4: Executor (if needed) ===\n        if verbose:\n            print(\"[3/4] Checking if execution needed...\")\n        \n        plan = self.executor.plan_execution(cloud_response)\n        \n        if plan.get(\"needs_tool\"):\n            if verbose:\n                print(f\"   → Tool selected: {plan.get('tool')}\")\n            result[\"execution_needed\"] = True\n            # Note: actual tool execution requires MCP integration\n            # This is the planning layer only\n            result[\"execution_result\"] = f\"[PLANNED] {plan.get('raw_plan', 'See cloud response')}\"\n        \n        # === Step 5: Final Answer ===\n        # ถ้า cloud ให้คำตอบตรงๆ ใช้เลย\n        if \"Action:\" not in cloud_response and \"Tool:\" not in cloud_response:\n            result[\"final_answer\"] = cloud_response\n        \n        return result\n    \n    def run_simple(self, user_input: str) -> str:\n        \"\"\"Simple mode: แค่ส่ง input แล้วรับ final answer\"\"\"\n        result = self.run(user_input)\n        return result.get(\"final_answer\") or result.get(\"cloud_response\") or \"No response\"\n\n\n# ============================================================================\n# SECTION 7: CLI USAGE\n# ============================================================================\n\ndef main():\n    \"\"\"CLI entry point\"\"\"\n    if len(sys.argv) < 2:\n        print(\"Usage: python3 universal_bridge.py <thai_prompt>\")\n        print(\"       python3 universal_bridge.py --config  # show config\")\n        print(\"       python3 universal_bridge.py --history  # show history\")\n        sys.exit(1)\n    \n    if sys.argv[1] == \"--config\":\n        config = load_config()\n        print(json.dumps(config, indent=2, ensure_ascii=False))\n        return\n    \n    if sys.argv[1] == \"--history\":\n        bridge = UniversalAgentBridge()\n        print(bridge.history.summary())\n        print(bridge.history.get_context())\n        return\n    \n    # Normal execution\n    prompt = \" \".join(sys.argv[1:])\n    \n    print(f\"[Universal Agent Bridge]\")\n    print(f\"Input: {prompt[:80]}{'...' if len(prompt) > 80 else ''}\")\n    print(\"-\" * 50)\n    \n    bridge = UniversalAgentBridge()\n    result = bridge.run(prompt, verbose=True)\n    \n    print(\"-\" * 50)\n    print(\"[RESULT]\")\n    print(result.get(\"final_answer\") or result.get(\"cloud_response\"))\n\n\nif __name__ == \"__main__\":\n    main()","path":"/home/apinan/.openclaw/workspace/scripts/universal_bridge.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":185,"output":4690,"cacheRead":120704,"cacheWrite":0,"totalTokens":125579,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778241039147,"responseId":"064d01125cce9b5620576e3868cad124"}}
