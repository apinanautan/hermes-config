oding=\"utf-8\") as f:\n+        # OVERWRITE: โหมด 'w' ทับไฟล์เดิมตลอด = 1 ไฟล์เดียว ไม่สร้างใหม่\n+        with open(BRIDGE_INPUT, \"w\", encoding=\"utf-8\") as f:\n             f.write(f\"=== English Summary ===\\n{english_input}\\n\\n\")\n             if history_context:\n                 f.write(f\"=== Previous Context ===\\n{history_context}\\n\\n\")\n             f.write(f\"=== Model: {self.model} ===\\n\")\n         \n-        print(f\"📬 Summary saved to {output_file}\")\n+        print(f\"📬 Summary saved to /tmp/bridge/ (จะถูกลบเองตอนปิดเครื่อง)\")\n         \n         # ถ้ามี API key จริง ส่งไป Cloud ด้วยก็ได้\n         if self.api_key and self.api_key != \"dummy\":\n             return self._http_request(english_input, history_context, system)\n         else:\n-            return f\"[FILE_MODE] English summary saved. Awaiting Cloud response in {output_file}\"\n+            return f\"[FILE_MODE] English summary saved. Awaiting Cloud response in {BRIDGE_INPUT}\"\n     \n     def _http_request(self, english_input: str, history_context: str, system: str) -> str:\n         \"\"\"HTTP request ไป Cloud จริงๆ\"\"\"\n         full_prompt = f\"\"\"[User Input - English]\n@@ -414,24 +427,59 @@\n # ============================================================================\n # SECTION 6: MAIN BRIDGE CLASS\n # ============================================================================\n \n+class CleanupManager:\n+    \"\"\"\n+    Self-Destruct: ลบทุกไฟล์ buffer ทิ้งหลัง pipeline จบ\n+    Zero-Footprint = เครื่องเจ้านายสะอาดเหมือนเดิม\n+    \"\"\"\n+    \n+    BUFFERS = [BRIDGE_INPUT, BRIDGE_COMMAND]\n+    \n+    @staticmethod\n+    def wipe():\n+        \"\"\"ลบไฟล์สื่อสารทั้งหมดทิ้ง\"\"\"\n+        for f in CleanupManager.BUFFERS:\n+            try:\n+                if os.path.exists(f):\n+                    os.remove(f)\n+            except OSError:\n+                pass\n+        # ลบ folder เปล่าด้วย\n+        try:\n+            if os.path.isdir(BRIDGE_TMP) and not os.listdir(BRIDGE_TMP):\n+                shutil.rmtree(BRIDGE_TMP, ignore_errors=True)\n+        except OSError:\n+            pass\n+    \n+    @staticmethod\n+    def status() -> str:\n+        \"\"\"ตรวจว่ามี buffer ค้างไหม\"\"\"\n+        leftover = [f for f in CleanupManager.BUFFERS if os.path.exists(f)]\n+        if leftover:\n+            return f\"⚠ Buffer(s) found: {', '.join(leftover)}\"\n+        return \"✓ Clean — no leftover buffers\"\n+\n+\n class UniversalAgentBridge:\n     \"\"\"\n     สะพานเชื่อม Universal Agent Bridge\n     \n     ใช้งานง่าย:\n         bridge = UniversalAgentBridge()\n         result = bridge.run(\"คำสั่งภาษาไทย\")\n         print(result)\n+        bridge.cleanup()  # Zero-Footprint\n     \"\"\"\n     \n     def __init__(self, config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\"):\n         self.config = load_config(config_path)\n         self.history = ConversationHistory(limit=self.config[\"router\"][\"history_limit\"])\n         self.preprocessor = Preprocessor(self.config)\n         self.router = Router(self.config, self.history)\n         self.executor = Executor(self.config, self.preprocessor)\n+        _ensure_tmp()  # เตรียม /tmp/bridge/ ไว้ก่อน\n     \n     def run(self, user_input: str, verbose: bool = False) -> dict:\n         \"\"\"\n         Run full pipeline:\n@@ -492,19 +540,25 @@\n         if plan.get(\"needs_tool\"):\n             if verbose:\n                 print(f\"   → Tool selected: {plan.get('tool')}\")\n             result[\"execution_needed\"] = True\n-            # Note: actual tool execution requires MCP integration\n-            # This is the planning layer only\n             result[\"execution_result\"] = f\"[PLANNED] {plan.get('raw_plan', 'See cloud response')}\"\n         \n         # === Step 5: Final Answer ===\n-        # ถ้า cloud ให้คำตอบตรงๆ ใช้เลย\n         if \"Action:\" not in cloud_response and \"Tool:\" not in cloud_response:\n             result[\"final_answer\"] = cloud_response\n         \n+        # === 🔥 SELF-DESTRUCT: ลบไฟล์ buffer ทิ้ง ===\n+        self.cleanup()\n+        if verbose:\n+            print(\"[4/4] 🧹 Cleanup done — Zero Footprint\")\n+        \n         return result\n     \n+    def cleanup(self):\n+        \"\"\"ลบไฟล์สื่อสารทั้งหมด — เครื่องสะอาดเหมือนเดิม\"\"\"\n+        CleanupManager.wipe()\n+    \n     def run_simple(self, user_input: str) -> str:\n         \"\"\"Simple mode: แค่ส่ง input แล้วรับ final answer\"\"\"\n         result = self.run(user_input)\n         return result.get(\"final_answer\") or result.get(\"cloud_response\") or \"No response\"\n```\n\n"}],"details":{"mcpServer":"filesystem","mcpTool":"edit_file","structuredContent":{"content":"```diff\nIndex: /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\n===================================================================\n--- /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\toriginal\n+++ /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\tmodified\n@@ -15,16 +15,28 @@\n \"\"\"\n \n import json\n import os\n+import shutil\n import sys\n import time\n import urllib.request\n import urllib.error\n from pathlib import Path\n from typing import Optional\n \n # ============================================================================\n+# ZERO-FOOTPRINT: ทุกไฟล์ชั่วคราวอยู่ใน /tmp → ลบเองตอนปิดเครื่อง\n+# ============================================================================\n+BRIDGE_TMP = \"/tmp/bridge\"\n+BRIDGE_INPUT = f\"{BRIDGE_TMP}/input_to_cloud.txt\"\n+BRIDGE_COMMAND = f\"{BRIDGE_TMP}/command_from_cloud.txt\"\n+\n+def _ensure_tmp():\n+    \"\"\"สร้าง /tmp/bridge/ ถ้ายังไม่มี\"\"\"\n+    os.makedirs(BRIDGE_TMP, exist_ok=True)\n+\n+# ============================================================================\n # SECTION 1: CONFIGURATION\n # ============================================================================\n \"\"\"\n Config เก็บไว้ที่เดียว ง่ายต่อการสลับโมเดล\n@@ -274,26 +286,27 @@\n     \n     def send_to_cloud(self, english_input: str, system: str = \"\") -> str:\n         \"\"\"\n         ส่งไป Cloud ผ่านไฟล์ (ถ้าไม่มี key) หรือ HTTP (ถ้ามี key)\n+        ใช้ /tmp/bridge/ → ไฟล์ถูกลบเองตอนปิดเครื่อง\n         \"\"\"\n         history_context = self.history.get_context()\n-        output_file = \"/home/apinan/.openclaw/workspace/scripts/input_to_cloud.txt\"\n+        _ensure_tmp()\n         \n-        # เขียน summary + context ลงไฟล์\n-        with open(output_file, \"w\", encoding=\"utf-8\") as f:\n+        # OVERWRITE: โหมด 'w' ทับไฟล์เดิมตลอด = 1 ไฟล์เดียว ไม่สร้างใหม่\n+        with open(BRIDGE_INPUT, \"w\", encoding=\"utf-8\") as f:\n             f.write(f\"=== English Summary ===\\n{english_input}\\n\\n\")\n             if history_context:\n                 f.write(f\"=== Previous Context ===\\n{history_context}\\n\\n\")\n             f.write(f\"=== Model: {self.model} ===\\n\")\n         \n-        print(f\"📬 Summary saved to {output_file}\")\n+        print(f\"📬 Summary saved to /tmp/bridge/ (จะถูกลบเองตอนปิดเครื่อง)\")\n         \n         # ถ้ามี API key จริง ส่งไป Cloud ด้วยก็ได้\n         if self.api_key and self.api_key != \"dummy\":\n             return self._http_request(english_input, history_context, system)\n         else:\n-            return f\"[FILE_MODE] English summary saved. Awaiting Cloud response in {output_file}\"\n+            return f\"[FILE_MODE] English summary saved. Awaiting Cloud response in {BRIDGE_INPUT}\"\n     \n     def _http_request(self, english_input: str, history_context: str, system: str) -> str:\n         \"\"\"HTTP request ไป Cloud จริงๆ\"\"\"\n         full_prompt = f\"\"\"[User Input - English]\n@@ -414,24 +427,59 @@\n # ============================================================================\n # SECTION 6: MAIN BRIDGE CLASS\n # ============================================================================\n \n+class CleanupManager:\n+    \"\"\"\n+    Self-Destruct: ลบทุกไฟล์ buffer ทิ้งหลัง pipeline จบ\n+    Zero-Footprint = เครื่องเจ้านายสะอาดเหมือนเดิม\n+    \"\"\"\n+    \n+    BUFFERS = [BRIDGE_INPUT, BRIDGE_COMMAND]\n+    \n+    @staticmethod\n+    def wipe():\n+        \"\"\"ลบไฟล์สื่อสารทั้งหมดทิ้ง\"\"\"\n+        for f in CleanupManager.BUFFERS:\n+            try:\n+                if os.path.exists(f):\n+                    os.remove(f)\n+            except OSError:\n+                pass\n+        # ลบ folder เปล่าด้วย\n+        try:\n+            if os.path.isdir(BRIDGE_TMP) and not os.listdir(BRIDGE_TMP):\n+                shutil.rmtree(BRIDGE_TMP, ignore_errors=True)\n+        except OSError:\n+            pass\n+    \n+    @staticmethod\n+    def status() -> str:\n+        \"\"\"ตรวจว่ามี buffer ค้างไหม\"\"\"\n+        leftover = [f for f in CleanupManager.BUFFERS if os.path.exists(f)]\n+        if leftover:\n+            return f\"⚠ Buffer(s) found: {', '.join(leftover)}\"\n+        return \"✓ Clean — no leftover buffers\"\n+\n+\n class UniversalAgentBridge:\n     \"\"\"\n     สะพานเชื่อม Universal Agent Bridge\n     \n     ใช้งานง่าย:\n         bridge = UniversalAgentBridge()\n         result = bridge.run(\"คำสั่งภาษาไทย\")\n         print(result)\n+        bridge.cleanup()  # Zero-Footprint\n     \"\"\"\n     \n     def __init__(self, config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\"):\n         self.config = load_config(config_path)\n         self.history = ConversationHistory(limit=self.config[\"router\"][\"history_limit\"])\n         self.preprocessor = Preprocessor(self.config)\n         self.router = Router(self.config, self.history)\n         self.executor = Executor(self.config, self.preprocessor)\n+        _ensure_tmp()  # เตรียม /tmp/bridge/ ไว้ก่อน\n     \n     def run(self, user_input: str, verbose: bool = False) -> dict:\n         \"\"\"\n         Run full pipeline:\n@@ -492,19 +540,25 @@\n         if plan.get(\"needs_tool\"):\n             if verbose:\n                 print(f\"   → Tool selected: {plan.get('tool')}\")\n             result[\"execution_needed\"] = True\n-            # Note: actual tool execution requires MCP integration\n-            # This is the planning layer only\n             result[\"execution_result\"] = f\"[PLANNED] {plan.get('raw_plan', 'See cloud response')}\"\n         \n         # === Step 5: Final Answer ===\n-        # ถ้า cloud ให้คำตอบตรงๆ ใช้เลย\n         if \"Action:\" not in cloud_response and \"Tool:\" not in cloud_response:\n             result[\"final_answer\"] = cloud_response\n         \n+        # === 🔥 SELF-DESTRUCT: ลบไฟล์ buffer ทิ้ง ===\n+        self.cleanup()\n+        if verbose:\n+            print(\"[4/4] 🧹 Cleanup done — Zero Footprint\")\n+        \n         return result\n     \n+    def cleanup(self):\n+        \"\"\"ลบไฟล์สื่อสารทั้งหมด — เครื่องสะอาดเหมือนเดิม\"\"\"\n+        CleanupManager.wipe()\n+    \n     def run_simple(self, user_input: str) -> str:\n         \"\"\"Simple mode: แค่ส่ง input แล้วรับ final answer\"\"\"\n         result = self.run(user_input)\n         return result.get(\"final_answer\") or result.get(\"cloud_response\") or \"No response\"\n```\n\n"}},"isError":false,"timestamp":1778242223434}}
