{"type":"message","id":"c8091f51","parentId":"3e9e7fed","timestamp":"2026-05-08T13:19:01.272Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants me to add a \"Self-Healing Key\" system to the universal_bridge.py. Let me implement:\n\n1. A hierarchical key lookup function:\n   - Check ENV first\n   - Then check bridge_config.json\n   - Then scan system files (.env, gateway config) to auto-recover keys\n\n2. Rule: NEVER ask the boss for keys — auto-recover from known locations\n\n3. If found → proceed silently. If not found → report \"ระบบกู้คีย์ล้มเหลว\" (don't ask for keys)\n\nThen test by simulating a missing key and showing the self-healing process.\n\nLet me implement this. I need to:\n- Add a `KeyVault` class that knows where to look for keys\n- Integrate it into the Router\n- The vault should scan: env vars, bridge_config.json, ~/.openclaw/openclaw.json (for API keys), ~/.hermes/.env (which we already know has OLLAMA_PAY_API_KEY)\n- Test by running a scenario","thinkingSignature":"reasoning"},{"type":"toolCall","id":"call_t9pl8py4","name":"filesystem__edit_file","arguments":{"edits":[{"newText":"# ============================================================================\n# ZERO-FOOTPRINT: ทุกไฟล์ชั่วคราวอยู่ใน /tmp → ลบเองตอนปิดเครื่อง\n# ============================================================================\nBRIDGE_TMP = \"/tmp/bridge\"\nBRIDGE_INPUT = f\"{BRIDGE_TMP}/input_to_cloud.txt\"\nBRIDGE_COMMAND = f\"{BRIDGE_TMP}/command_from_cloud.txt\"\n\n# แหล่งคีย์ที่ระบบรู้จัก — สแกนตามลำดับนี้\nKEY_SOURCES = [\n    # ENV keys (เช็คก่อน)\n    (\"env\", \"OLLAMA_PAY_API_KEY\", None),\n    (\"env\", \"MINIMAX_API_KEY\", None),\n    (\"env\", \"DEEPSEEK_API_KEY\", None),\n    (\"env\", \"OPENAI_API_KEY\", None),\n    # bridge_config.json (json path, key)\n    (\"file\", \"~/.openclaw/workspace/scripts/bridge_config.json\", \"cloud.api_key\"),\n    # openclaw.json — อาจมี key ฝังไว้\n    (\"file\", \"~/.openclaw/openclaw.json\", \"providers.minimax.api_key\"),\n    # Hermes .env — ต้นทางคีย์จริงของเจ้านาย\n    (\"dotenv\", \"~/.hermes/.env\", \"OLLAMA_PAY_API_KEY\"),\n    (\"dotenv\", \"~/.hermes/.env\", \"MINIMAX_API_KEY\"),\n    (\"dotenv\", \"~/.hermes/.env\", \"DEEPSEEK_API_KEY\"),\n]\n\ndef _ensure_tmp():\n    \"\"\"สร้าง /tmp/bridge/ ถ้ายังไม่มี\"\"\"\n    os.makedirs(BRIDGE_TMP, exist_ok=True)\n\n\n# ============================================================================\n# SELF-HEALING KEY VAULT — ห้ามถามเจ้านายเรื่องคีย์เด็ดขาด\n# ============================================================================\n\nclass KeyVault:\n    \"\"\"\n    กู้คีย์อัตโนมัติแบบลำดับชั้น:\n      ENV → config.json → ไฟล์ระบบ → .env ของ Hermes\n    \n    ถ้าหาไม่เจอ → report 'ระบบกู้คีย์ล้มเหลว' (ไม่ถามเจ้านาย)\n    \"\"\"\n    \n    @staticmethod\n    def find(key_name: str = \"OLLAMA_PAY_API_KEY\") -> Optional[str]:\n        \"\"\"ค้นหาคีย์ตามลำดับชั้น — คืนค่า key หรือ None\"\"\"\n        \n        # Layer 1: Environment variable\n        val = os.environ.get(key_name, \"\")\n        if val and len(val) > 10:\n            return val\n        \n        # Layer 2: bridge_config.json\n        cfg_path = Path(\"~/.openclaw/workspace/scripts/bridge_config.json\").expanduser()\n        if cfg_path.exists():\n            try:\n                with open(cfg_path) as f:\n                    cfg = json.load(f)\n                # เช็ค cloud.api_key\n                cloud_cfg = cfg.get(\"cloud\", {})\n                api_key = cloud_cfg.get(\"api_key\", \"\")\n                if api_key and len(api_key) > 10:\n                    os.environ[key_name] = api_key  # ฝังกลับเข้า ENV\n                    return api_key\n            except Exception:\n                pass\n        \n        # Layer 3: สแกนไฟล์ระบบที่รู้จัก\n        for source_path in [\"~/.openclaw/openclaw.json\"]:\n            p = Path(source_path).expanduser()\n            if not p.exists():\n                continue\n            try:\n                with open(p) as f:\n                    data = json.load(f)\n                # ค้นหา key แบบ recursive\n                found = KeyVault._deep_search(data, [\"api_key\", \"apiKey\", \"key\"])\n                if found:\n                    os.environ[key_name] = found\n                    return found\n            except Exception:\n                pass\n        \n        # Layer 4: Hermes .env (ต้นทางจริง)\n        hermes_env = Path(\"~/.hermes/.env\").expanduser()\n        if hermes_env.exists():\n            try:\n                with open(hermes_env) as f:\n                    for line in f:\n                        line = line.strip()\n                        if line.startswith(\"#\") or \"=\" not in line:\n                            continue\n                        k, v = line.split(\"=\", 1)\n                        k = k.strip()\n                        v = v.strip().strip('\"').strip(\"'\")\n                        if k == key_name and len(v) > 10:\n                            os.environ[key_name] = v\n                            return v\n            except Exception:\n                pass\n        \n        return None  # หาไม่เจอจริงๆ\n    \n    @staticmethod\n    def _deep_search(obj, keys: list[str]) -> Optional[str]:\n        \"\"\"ค้นหา key ใน nested dict/list\"\"\"\n        if isinstance(obj, str) and len(obj) > 10 and any(k in obj.lower() for k in [\"sk-\", \"eyj\", \"bearer\"]):\n            return obj\n        if isinstance(obj, dict):\n            for k, v in obj.items():\n                if k in keys and isinstance(v, str) and len(v) > 10:\n                    return v\n                result = KeyVault._deep_search(v, keys)\n                if result:\n                    return result\n        elif isinstance(obj, list):\n            for item in obj:\n                result = KeyVault._deep_search(item, keys)\n                if result:\n                    return result\n        return None\n    \n    @staticmethod\n    def status(key_name: str = \"OLLAMA_PAY_API_KEY\") -> dict:\n        \"\"\"รายงานสถานะการกู้คีย์\"\"\"\n        key = KeyVault.find(key_name)\n        if key:\n            return {\n                \"found\": True,\n                \"source\": \"env\" if os.environ.get(key_name) == key else \"file\",\n                \"prefix\": key[:8] + \"...\",\n            }\n        return {\"found\": False, \"reason\": \"ระบบกู้คีย์ล้มเหลว — ไม่พบคีย์ในทุกแหล่ง\"}","oldText":"# ============================================================================\n# ZERO-FOOTPRINT: ทุกไฟล์ชั่วคราวอยู่ใน /tmp → ลบเองตอนปิดเครื่อง\n# ============================================================================\nBRIDGE_TMP = \"/tmp/bridge\"\nBRIDGE_INPUT = f\"{BRIDGE_TMP}/input_to_cloud.txt\"\nBRIDGE_COMMAND = f\"{BRIDGE_TMP}/command_from_cloud.txt\"\n\ndef _ensure_tmp():\n    \"\"\"สร้าง /tmp/bridge/ ถ้ายังไม่มี\"\"\"\n    os.makedirs(BRIDGE_TMP, exist_ok=True)"}],"path":"/home/apinan/.openclaw/workspace/scripts/universal_bridge.py"}}],"api":"openai-completions","provider":"ollama-pay","model":"deepseek-v4-pro:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778246274052,"responseId":"chatcmpl-1778246307369"}}
{"type":"message","id":"1edd380b","parentId":"c8091f51","timestamp":"2026-05-08T13:19:01.339Z","message":{"role":"toolResult","toolCallId":"call_t9pl8py4","toolName":"filesystem__edit_file","content":[{"type":"text","text":"```diff\nIndex: /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\n===================================================================\n--- /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\toriginal\n+++ /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\tmodified\n@@ -30,13 +30,134 @@\n BRIDGE_TMP = \"/tmp/bridge\"\n BRIDGE_INPUT = f\"{BRIDGE_TMP}/input_to_cloud.txt\"\n BRIDGE_COMMAND = f\"{BRIDGE_TMP}/command_from_cloud.txt\"\n \n+# แหล่งคีย์ที่ระบบรู้จัก — สแกนตามลำดับนี้\n+KEY_SOURCES = [\n+    # ENV keys (เช็คก่อน)\n+    (\"env\", \"OLLAMA_PAY_API_KEY\", None),\n+    (\"env\", \"MINIMAX_API_KEY\", None),\n+    (\"env\", \"DEEPSEEK_API_KEY\", None),\n+    (\"env\", \"OPENAI_API_KEY\", None),\n+    # bridge_config.json (json path, key)\n+    (\"file\", \"~/.openclaw/workspace/scripts/bridge_config.json\", \"cloud.api_key\"),\n+    # openclaw.json — อาจมี key ฝังไว้\n+    (\"file\", \"~/.openclaw/openclaw.json\", \"providers.minimax.api_key\"),\n+    # Hermes .env — ต้นทางคีย์จริงของเจ้านาย\n+    (\"dotenv\", \"~/.hermes/.env\", \"OLLAMA_PAY_API_KEY\"),\n+    (\"dotenv\", \"~/.hermes/.env\", \"MINIMAX_API_KEY\"),\n+    (\"dotenv\", \"~/.hermes/.env\", \"DEEPSEEK_API_KEY\"),\n+]\n+\n def _ensure_tmp():\n     \"\"\"สร้าง /tmp/bridge/ ถ้ายังไม่มี\"\"\"\n     os.makedirs(BRIDGE_TMP, exist_ok=True)\n \n+\n # ============================================================================\n+# SELF-HEALING KEY VAULT — ห้ามถามเจ้านายเรื่องคีย์เด็ดขาด\n+# ============================================================================\n+\n+class KeyVault:\n+    \"\"\"\n+    กู้คีย์อัตโนมัติแบบลำดับชั้น:\n+      ENV → config.json → ไฟล์ระบบ → .env ของ Hermes\n+    \n+    ถ้าหาไม่เจอ → report 'ระบบกู้คีย์ล้มเหลว' (ไม่ถามเจ้านาย)\n+    \"\"\"\n+    \n+    @staticmethod\n+    def find(key_name: str = \"OLLAMA_PAY_API_KEY\") -> Optional[str]:\n+        \"\"\"ค้นหาคีย์ตามลำดับชั้น — คืนค่า key หรือ None\"\"\"\n+        \n+        # Layer 1: Environment variable\n+        val = os.environ.get(key_name, \"\")\n+        if val and len(val) > 10:\n+            return val\n+        \n+        # Layer 2: bridge_config.json\n+        cfg_path = Path(\"~/.openclaw/workspace/scripts/bridge_config.json\").expanduser()\n+        if cfg_path.exists():\n+            try:\n+                with open(cfg_path) as f:\n+                    cfg = json.load(f)\n+                # เช็ค cloud.api_key\n+                cloud_cfg = cfg.get(\"cloud\", {})\n+                api_key = cloud_cfg.get(\"api_key\", \"\")\n+                if api_key and len(api_key) > 10:\n+                    os.environ[key_name] = api_key  # ฝังกลับเข้า ENV\n+                    return api_key\n+            except Exception:\n+                pass\n+        \n+        # Layer 3: สแกนไฟล์ระบบที่รู้จัก\n+        for source_path in [\"~/.openclaw/openclaw.json\"]:\n+            p = Path(source_path).expanduser()\n+            if not p.exists():\n+                continue\n+            try:\n+                with open(p) as f:\n+                    data = json.load(f)\n+                # ค้นหา key แบบ recursive\n+                found = KeyVault._deep_search(data, [\"api_key\", \"apiKey\", \"key\"])\n+                if found:\n+                    os.environ[key_name] = found\n+                    return found\n+            except Exception:\n+                pass\n+        \n+        # Layer 4: Hermes .env (ต้นทางจริง)\n+        hermes_env = Path(\"~/.hermes/.env\").expanduser()\n+        if hermes_env.exists():\n+            try:\n+                with open(hermes_env) as f:\n+                    for line in f:\n+                        line = line.strip()\n+                        if line.startswith(\"#\") or \"=\" not in line:\n+                            continue\n+                        k, v = line.split(\"=\", 1)\n+                        k = k.strip()\n+                        v = v.strip().strip('\"').strip(\"'\")\n+                        if k == key_name and len(v) > 10:\n+                            os.environ[key_name] = v\n+                            return v\n+            except Exception:\n+                pass\n+        \n+        return None  # หาไม่เจอจริงๆ\n+    \n+    @staticmethod\n+    def _deep_search(obj, keys: list[str]) -> Optional[str]:\n+        \"\"\"ค้นหา key ใน nested dict/list\"\"\"\n+        if isinstance(obj, str) and len(obj) > 10 and any(k in obj.lower() for k in [\"sk-\", \"eyj\", \"bearer\"]):\n+            return obj\n+        if isinstance(obj, dict):\n+            for k, v in obj.items():\n+                if k in keys and isinstance(v, str) and len(v) > 10:\n+                    return v\n+                result = KeyVault._deep_search(v, keys)\n+                if result:\n+                    return result\n+        elif isinstance(obj, list):\n+            for item in obj:\n+                result = KeyVault._deep_search(item, keys)\n+                if result:\n+                    return result\n+        return None\n+    \n+    @staticmethod\n+    def status(key_name: str = \"OLLAMA_PAY_API_KEY\") -> dict:\n+        \"\"\"รายงานสถานะการกู้คีย์\"\"\"\n+        key = KeyVault.find(key_name)\n+        if key:\n+            return {\n+                \"found\": True,\n+                \"source\": \"env\" if os.environ.get(key_name) == key else \"file\",\n+                \"prefix\": key[:8] + \"...\",\n+            }\n+        return {\"found\": False, \"reason\": \"ระบบกู้คีย์ล้มเหลว — ไม่พบคีย์ในทุกแหล่ง\"}\n+\n+# ============================================================================\n # SECTION 1: CONFIGURATION\n # ============================================================================\n \"\"\"\n Config เก็บไว้ที่เดียว ง่ายต่อการสลับโมเดล\n```\n\n"}],"details":{"mcpServer":"filesystem","mcpTool":"edit_file","structuredContent":{"content":"```diff\nIndex: /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\n===================================================================\n--- /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\toriginal\n+++ /home/apinan/.openclaw/workspace/scripts/universal_bridge.py\tmodified\n@@ -30,13 +30,134 @@\n BRIDGE_TMP = \"/tmp/bridge\"\n BRIDGE_INPUT = f\"{BRIDGE_TMP}/input_to_cloud.txt\"\n BRIDGE_COMMAND = f\"{BRIDGE_TMP}/command_from_cloud.txt\"\n \n+# แหล่งคีย์ที่ระบบรู้จัก — สแกนตามลำดับนี้\n+KEY_SOURCES = [\n+    # ENV keys (เช็คก่อน)\n+    (\"env\", \"OLLAMA_PAY_API_KEY\", None),\n+    (\"env\", \"MINIMAX_API_KEY\", None),\n+    (\"env\", \"DEEPSEEK_API_KEY\", None),\n+    (\"env\", \"OPENAI_API_KEY\", None),\n+    # bridge_config.json (json path, key)\n+    (\"file\", \"~/.openclaw/workspace/scripts/bridge_config.json\", \"cloud.api_key\"),\n+    # openclaw.json — อาจมี key ฝังไว้\n+    (\"file\", \"~/.openclaw/openclaw.json\", \"providers.minimax.api_key\"),\n+    # Hermes .env — ต้นทางคีย์จริงของเจ้านาย\n+    (\"dotenv\", \"~/.hermes/.env\", \"OLLAMA_PAY_API_KEY\"),\n+    (\"dotenv\", \"~/.hermes/.env\", \"MINIMAX_API_KEY\"),\n+    (\"dotenv\", \"~/.hermes/.env\", \"DEEPSEEK_API_KEY\"),\n+]\n+\n def _ensure_tmp():\n     \"\"\"สร้าง /tmp/bridge/ ถ้ายังไม่มี\"\"\"\n     os.makedirs(BRIDGE_TMP, exist_ok=True)\n \n+\n # ============================================================================\n+# SELF-HEALING KEY VAULT — ห้ามถามเจ้านายเรื่องคีย์เด็ดขาด\n+# ============================================================================\n+\n+class KeyVault:\n+    \"\"\"\n+    กู้คีย์อัตโนมัติแบบลำดับชั้น:\n+      ENV → config.json → ไฟล์ระบบ → .env ของ Hermes\n+    \n+    ถ้าหาไม่เจอ → report 'ระบบกู้คีย์ล้มเหลว' (ไม่ถามเจ้านาย)\n+    \"\"\"\n+    \n+    @staticmethod\n+    def find(key_name: str = \"OLLAMA_PAY_API_KEY\") -> Optional[str]:\n+        \"\"\"ค้นหาคีย์ตามลำดับชั้น — คืนค่า key หรือ None\"\"\"\n+        \n+        # Layer 1: Environment variable\n+        val = os.environ.get(key_name, \"\")\n+        if val and len(val) > 10:\n+            return val\n+        \n+        # Layer 2: bridge_config.json\n+        cfg_path = Path(\"~/.openclaw/workspace/scripts/bridge_config.json\").expanduser()\n+        if cfg_path.exists():\n+            try:\n+                with open(cfg_path) as f:\n+                    cfg = json.load(f)\n+                # เช็ค cloud.api_key\n+                cloud_cfg = cfg.get(\"cloud\", {})\n+                api_key = cloud_cfg.get(\"api_key\", \"\")\n+                if api_key and len(api_key) > 10:\n+                    os.environ[key_name] = api_key  # ฝังกลับเข้า ENV\n+                    return api_key\n+            except Exception:\n+                pass\n+        \n+        # Layer 3: สแกนไฟล์ระบบที่รู้จัก\n+        for source_path in [\"~/.openclaw/openclaw.json\"]:\n+            p = Path(source_path).expanduser()\n+            if not p.exists():\n+                continue\n+            try:\n+                with open(p) as f:\n+                    data = json.load(f)\n+                # ค้นหา key แบบ recursive\n+                found = KeyVault._deep_search(data, [\"api_key\", \"apiKey\", \"key\"])\n+                if found:\n+                    os.environ[key_name] = found\n+                    return found\n+            except Exception:\n+                pass\n+        \n+        # Layer 4: Hermes .env (ต้นทางจริง)\n+        hermes_env = Path(\"~/.hermes/.env\").expanduser()\n+        if hermes_env.exists():\n+            try:\n+                with open(hermes_env) as f:\n+                    for line in f:\n+                        line = line.strip()\n+                        if line.startswith(\"#\") or \"=\" not in line:\n+                            continue\n+                        k, v = line.split(\"=\", 1)\n+                        k = k.strip()\n+                        v = v.strip().strip('\"').strip(\"'\")\n+                        if k == key_name and len(v) > 10:\n+                            os.environ[key_name] = v\n+                            return v\n+            except Exception:\n+                pass\n+        \n+        return None  # หาไม่เจอจริงๆ\n+    \n+    @staticmethod\n+    def _deep_search(obj, keys: list[str]) -> Optional[str]:\n+        \"\"\"ค้นหา key ใน nested dict/list\"\"\"\n+        if isinstance(obj, str) and len(obj) > 10 and any(k in obj.lower() for k in [\"sk-\", \"eyj\", \"bearer\"]):\n+            return obj\n+        if isinstance(obj, dict):\n+            for k, v in obj.items():\n+                if k in keys and isinstance(v, str) and len(v) > 10:\n+                    return v\n+                result = KeyVault._deep_search(v, keys)\n+                if result:\n+                    return result\n+        elif isinstance(obj, list):\n+            for item in obj:\n+                result = KeyVault._deep_search(item, keys)\n+                if result:\n+                    return result\n+        return None\n+    \n+    @staticmethod\n+    def status(key_name: str = \"OLLAMA_PAY_API_KEY\") -> dict:\n+        \"\"\"รายงานสถานะการกู้คีย์\"\"\"\n+        key = KeyVault.find(key_name)\n+        if key:\n+            return {\n+                \"found\": True,\n+                \"source\": \"env\" if os.environ.get(key_name) == key else \"file\",\n+                \"prefix\": key[:8] + \"...\",\n+            }\n+        return {\"found\": False, \"reason\": \"ระบบกู้คีย์ล้มเหลว — ไม่พบคีย์ในทุกแหล่ง\"}\n+\n+# ============================================================================\n # SECTION 1: CONFIGURATION\n # ============================================================================\n \"\"\"\n Config เก็บไว้ที่เดียว ง่ายต่อการสลับโมเดล\n```\n\n"}},"isError":false,"timestamp":1778246341338}}
{"type":"message","id":"024d0fb6","parentId":"1edd380b","timestamp":"2026-05-08T13:19:46.929Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, the KeyVault class is added. Now I need to update the Router to use KeyVault instead of directly reading from os.environ. Let me update the Router's __init__ to use KeyVault.find() for the API key.","thinkingSignature":"reasoning"},{"type":"text","text":"Now update Router to use KeyVault:"},{"type":"toolCall","id":"call_hwip84nz","name":"filesystem__edit_file","arguments":{"edits":[{"newText":"class Router:\n    \"\"\"ส่ง English summary ไป Cloud (Self-Healing Key)\"\"\"\n    \n    def __init__(self, config: dict, history: ConversationHistory):\n        self.config = config[\"cloud\"]\n        self.base_url = self.config[\"base_url\"]\n        self.model = self.config[\"model\"]\n        self.key_name = self.config[\"api_key_env\"]\n        self.history = history\n        # 🔥 Self-Healing: กู้คีย์อัตโนมัติ ไม่ถามเจ้านาย\n        self.api_key = KeyVault.find(self.key_name) or \"\"\n        self.key_status = KeyVault.status(self.key_name)\n    \n    def send_to_cloud(self, english_input: str, system: str = \"\") -> str:\n        \"\"\"\n        ส่งไป Cloud — ถ้ามี key ใช้ HTTP, ถ้าไม่มีใช้ FILE_MODE\n        \"\"\"\n        history_context = self.history.get_context()\n        _ensure_tmp()\n        \n        # เขียน buffer ไว้เสมอ (overwrite)\n        with open(BRIDGE_INPUT, \"w\", encoding=\"utf-8\") as f:\n            f.write(f\"=== English Summary ===\\n{english_input}\\n\\n\")\n            if history_context:\n                f.write(f\"=== Previous Context ===\\n{history_context}\\n\\n\")\n            f.write(f\"=== Model: {self.model} ===\\n\")\n        \n        # ถ้ามีคีย์ → ยิง Cloud จริง\n        if self.api_key and len(self.api_key) > 10:\n            return self._http_request(english_input, history_context, system)\n        else:\n            return f\"[FILE_MODE] ระบบกู้คีย์ล้มเหลว — โปรดตรวจสอบแหล่งคีย์\"","oldText":"class Router:\n    \"\"\"ส่ง English summary ไป Cloud (ผ่านไฟล์ ถ้าไม่มี API key)\"\"\"\n    \n    def __init__(self, config: dict, history: ConversationHistory):\n        self.config = config[\"cloud\"]\n        self.base_url = self.config[\"base_url\"]\n        self.model = self.config[\"model\"]\n        self.api_key = os.environ.get(self.config[\"api_key_env\"], \"\")\n        self.history = history\n    \n    def send_to_cloud(self, english_input: str, system: str = \"\") -> str:\n        \"\"\"\n        ส่งไป Cloud ผ่านไฟล์ (ถ้าไม่มี key) หรือ HTTP (ถ้ามี key)\n        ใช้ /tmp/bridge/ → ไฟล์ถูกลบเองตอนปิดเครื่อง\n        \"\"\"\n        history_context = self.history.get_context()\n        _ensure_tmp()\n        \n        # OVERWRITE: โหมด 'w' ทับไฟล์เดิมตลอด = 1 ไฟล์เดียว ไม่สร้างใหม่\n        with open(BRIDGE_INPUT, \"w\", encoding=\"utf-8\") as f:\n            f.write(f\"=== English Summary ===\\n{english_input}\\n\\n\")\n            if history_context:\n                f.write(f\"=== Previous Context ===\\n{history_context}\\n\\n\")\n            f.write(f\"=== Model: {self.model} ===\\n\")\n        \n        print(f\"📬 Summary saved to /tmp/bridge/ (จะถูกลบเองตอนปิดเครื่อง)\")\n        \n        # ถ้ามี API key จริง ส่งไป Cloud ด้วยก็ได้\n        if self.api_key and self.api_key != \"dummy\":\n            return self._http_request(english_input, history_context, system)\n        else:\n            return f\"[FILE_MODE] English summary saved. Awaiting Cloud response in {BRIDGE_INPUT}\""}],"path":"/home/apinan/.openclaw/workspace/scripts/universal_bridge.py"}}],"api":"openai-completions","provider":"ollama-pay","model":"deepseek-v4-pro:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778246341343,"responseId":"chatcmpl-1778246361161"}}
