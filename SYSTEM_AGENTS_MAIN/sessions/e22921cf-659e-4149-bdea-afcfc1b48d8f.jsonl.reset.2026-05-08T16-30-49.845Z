7: รับผลลัพธ์จาก Executor → ส่งให้ Cloud (MiniMax) สรุปเป็นไทยสั้นๆ\n+    \"\"\"\n+    \n+    def __init__(self, config: dict):\n+        self.cloud_cfg = config[\"cloud\"]\n+        self.local_cfg = config[\"local\"]\n+        self.key_name = self.cloud_cfg[\"api_key_env\"]\n+        # Self-healing key\n+        self.api_key = KeyVault.find(self.key_name) or \"\"\n+    \n+    def summarize(self, original_prompt: str, execution_result: dict) -> str:\n+        \"\"\"\n+        ส่งผลลัพธ์ให้ Cloud สรุปเป็นไทย\n+        Returns: Thai summary string\n+        \"\"\"\n+        if not execution_result.get(\"outputs\"):\n+            return f\"[สรุป] ไม่มีผลลัพธ์จากการรันคำสั่งสำหรับ: {original_prompt}\"\n+        \n+        raw_output = execution_result.get(\"raw\", \"\")\n+        if len(raw_output) > 3000:\n+            raw_output = raw_output[:3000] + \"...(trimmed)\"\n+        \n+        summary_prompt = f\"\"\"Summarize the following command execution results in THAI (ภาษาไทย).\n+Be very concise — 2-3 sentences maximum.\n+\n+Original request: {original_prompt}\n+\n+Execution results:\n+{raw_output}\n+\n+Thai summary:\"\"\"\n+        \n+        # ถ้ามี cloud key → ใช้ MiniMax\n+        if self.api_key and len(self.api_key) > 10:\n+            try:\n+                return call_llm(\n+                    self.cloud_cfg[\"base_url\"],\n+                    self.cloud_cfg[\"model\"],\n+                    summary_prompt,\n+                    api_key=self.api_key,\n+                    system=\"You summarize command outputs in Thai. Be short and clear.\",\n+                    timeout=120\n+                )\n+            except Exception as e:\n+                pass  # fallback below\n+        \n+        # Fallback: ใช้ Local LLM\n+        return call_llm(\n+            self.local_cfg[\"base_url\"],\n+            self.local_cfg[\"model\"],\n+            summary_prompt,\n+            api_key=self.local_cfg[\"api_key\"],\n+            system=\"You summarize in Thai. Be short.\",\n+            timeout=90\n+        )\n+\n+\n+# ============================================================================\n+# SECTION 7: MAIN BRIDGE CLASS (Complete 8/8 Pipeline)\n+# ============================================================================\n+\n class CleanupManager:\n     \"\"\"\n     Self-Destruct: ลบทุกไฟล์ buffer ทิ้งหลัง pipeline จบ\n     Zero-Footprint = เครื่องเจ้านายสะอาดเหมือนเดิม\n```\n\n"}},"isError":false,"timestamp":1778247013931}}
{"type":"message","id":"412fe993","parentId":"b28ebdf2","timestamp":"2026-05-08T13:30:48.895Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to update the UniversalAgentBridge class to:\n1. Include the Summarizer\n2. Update the run() method to include Steps 6 (execution) and 7 (summarization)\n3. Mark each step clearly","thinkingSignature":"reasoning"},{"type":"text","text":"Now update the main Bridge class with complete 8-step pipeline:"},{"type":"toolCall","id":"call_jj7wbd5o","name":"filesystem__edit_file","arguments":{"edits":[{"newText":"    def __init__(self, config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\"):\n        self.config = load_config(config_path)\n        self.history = ConversationHistory(limit=self.config[\"router\"][\"history_limit\"])\n        self.preprocessor = Preprocessor(self.config)\n        self.router = Router(self.config, self.history)\n        self.executor = Executor(self.config, self.preprocessor)\n        self.summarizer = Summarizer(self.config)\n        _ensure_tmp()\n    \n    def run(self, user_input: str, verbose: bool = False) -> dict:\n        \"\"\"\n        COMPLETE 8-STEP PIPELINE:\n        [1] INPUT → [2] GATEWAY → [3] PREPROCESS → [4] ROUTE → [5] RESPONSE\n        → [6] EXECUTE → [7] SUMMARIZE → [8] CLEANUP\n        \"\"\"\n        result = {\n            \"step1_input\": \"\", \"step3_english\": \"\", \"step4_cloud_sent\": False,\n            \"step5_cloud_response\": \"\", \"step6_execution\": {}, \"step7_summary\": \"\",\n            \"step8_cleanup\": False\n        }\n        \n        # === [Step 1-2]: INPUT + GATEWAY (รับไว้ใน local) ===\n        result[\"step1_input\"] = user_input\n        if verbose:\n            print(f\"[Step 1-2] INPUT: {user_input[:80]}...\")\n        \n        # === [Step 3]: FORCE TRANSLATE TH→EN ===\n        english, was_summarized = self.preprocessor.translate(user_input)\n        result[\"step3_english\"] = english\n        if verbose:\n            print(f\"[Step 3] FORCE TRANSLATE: {english[:100]}\")\n        \n        # === [Step 4-5]: ROUTE → CLOUD RESPONSE ===\n        cloud_response = self.router.send_to_cloud(english)\n        result[\"step5_cloud_response\"] = cloud_response\n        result[\"step4_cloud_sent\"] = not cloud_response.startswith(\"[FILE_MODE]\")\n        if verbose:\n            print(f\"[Step 4-5] CLOUD: {'✅ Cloud ตอบ' if result['step4_cloud_sent'] else '⚠️ FILE_MODE'}\")\n        \n        # === [Step 6]: EXECUTE FOR REAL ===\n        exec_result = self.executor.execute(cloud_response)\n        result[\"step6_execution\"] = exec_result\n        if verbose:\n            print(f\"[Step 6] EXECUTE: {exec_result['commands_run']} commands, success={exec_result['success']}\")\n            for r in exec_result.get(\"outputs\", []):\n                print(f\"   $ {r['command']}\")\n                print(f\"   → {r['output'][:120]}\")\n        \n        # === [Step 7]: SUMMARIZE (MiniMax → ไทยสั้นๆ) ===\n        summary = self.summarizer.summarize(user_input, exec_result)\n        result[\"step7_summary\"] = summary\n        if verbose:\n            print(f\"[Step 7] SUMMARIZE: {summary[:150]}\")\n        \n        # === [Step 8]: CLEANUP Zero Footprint ===\n        self.history.add(\"user\", user_input[:300])\n        self.history.add(\"result\", summary[:300])\n        self.cleanup()\n        result[\"step8_cleanup\"] = True\n        if verbose:\n            print(f\"[Step 8] CLEANUP ✅ Zero Footprint\")\n        \n        return result","oldText":"    def __init__(self, config_path: str = \"~/.openclaw/workspace/scripts/bridge_config.json\"):\n        self.config = load_config(config_path)\n        self.history = ConversationHistory(limit=self.config[\"router\"][\"history_limit\"])\n        self.preprocessor = Preprocessor(self.config)\n        self.router = Router(self.config, self.history)\n        self.executor = Executor(self.config, self.preprocessor)\n        _ensure_tmp()  # เตรียม /tmp/bridge/ ไว้ก่อน\n    \n    def run(self, user_input: str, verbose: bool = False) -> dict:\n        \"\"\"\n        Run full pipeline:\n        1. Preprocess (Local LLM)\n        2. Route to Cloud\n        3. Execute locally if needed\n        \n        Returns dict with:\n        - english_input\n        - cloud_response\n        - execution_result\n        - final_answer\n        \"\"\"\n        result = {\n            \"english_input\": \"\",\n            \"was_summarized\": False,\n            \"cloud_response\": \"\",\n            \"execution_needed\": False,\n            \"execution_result\": \"\",\n            \"final_answer\": \"\"\n        }\n        \n        # === Step 1: Preprocessor ===\n        if verbose:\n            print(\"[1/4] Preprocessing...\")\n        \n        english_input, was_summarized = self.preprocessor.translate(\n            user_input,\n            threshold=self.config[\"router\"][\"max_local_tokens\"]\n        )\n        result[\"english_input\"] = english_input\n        result[\"was_summarized\"] = was_summarized\n        \n        if verbose:\n            print(f\"   → English: {english_input[:100]}...\")\n            print(f\"   → Summarized: {was_summarized}\")\n        \n        # === Step 2: Router (Cloud) ===\n        if verbose:\n            print(\"[2/4] Sending to Cloud...\")\n        \n        cloud_response = self.router.send_to_cloud(english_input)\n        result[\"cloud_response\"] = cloud_response\n        \n        if verbose:\n            print(f\"   → Cloud responded ({len(cloud_response)} chars)\")\n        \n        # === Step 3: Update History ===\n        self.history.add(\"user\", user_input[:500])  # Trim long input\n        self.history.add(\"assistant\", cloud_response[:500])  # Trim long response\n        \n        # === Step 4: Executor (if needed) ===\n        if verbose:\n            print(\"[3/4] Checking if execution needed...\")\n        \n        plan = self.executor.plan_execution(cloud_response)\n        \n        if plan.get(\"needs_tool\"):\n            if verbose:\n                print(f\"   → Tool selected: {plan.get('tool')}\")\n            result[\"execution_needed\"] = True\n            result[\"execution_result\"] = f\"[PLANNED] {plan.get('raw_plan', 'See cloud response')}\"\n        \n        # === Step 5: Final Answer ===\n        if \"Action:\" not in cloud_response and \"Tool:\" not in cloud_response:\n            result[\"final_answer\"] = cloud_response\n        \n        # === 🔥 SELF-DESTRUCT: ลบไฟล์ buffer ทิ้ง ===\n        self.cleanup()\n        if verbose:\n            print(\"[4/4] 🧹 Cleanup done — Zero Footprint\")\n        \n        return result"}],"path":"/home/apinan/.openclaw/workspace/scripts/universal_bridge.py"}}],"api":"openai-completions","provider":"ollama-pay","model":"deepseek-v4-pro:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778247013938,"responseId":"chatcmpl-1778247029705"}}
