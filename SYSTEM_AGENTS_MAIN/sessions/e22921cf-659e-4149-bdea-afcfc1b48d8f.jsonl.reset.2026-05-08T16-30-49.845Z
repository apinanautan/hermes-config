{"type":"message","id":"22edf886","parentId":"caa26165","timestamp":"2026-05-08T13:30:13.917Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, the Executor is now updated with subprocess execution. Now I need to add the Summarizer class (Step 7) and update the main UniversalAgentBridge.run() method to include all steps. Let me add the Summarizer and update the pipeline.","thinkingSignature":"reasoning"},{"type":"text","text":"Now add Summarizer (Step 7) and update the main pipeline:"},{"type":"toolCall","id":"call_gs1qwm88","name":"filesystem__edit_file","arguments":{"edits":[{"newText":"# ============================================================================\n# SECTION 6: SUMMARIZER (Step 7 — MiniMax สรุปไทยสั้นๆ)\n# ============================================================================\n\nclass Summarizer:\n    \"\"\"\n    Step 7: รับผลลัพธ์จาก Executor → ส่งให้ Cloud (MiniMax) สรุปเป็นไทยสั้นๆ\n    \"\"\"\n    \n    def __init__(self, config: dict):\n        self.cloud_cfg = config[\"cloud\"]\n        self.local_cfg = config[\"local\"]\n        self.key_name = self.cloud_cfg[\"api_key_env\"]\n        # Self-healing key\n        self.api_key = KeyVault.find(self.key_name) or \"\"\n    \n    def summarize(self, original_prompt: str, execution_result: dict) -> str:\n        \"\"\"\n        ส่งผลลัพธ์ให้ Cloud สรุปเป็นไทย\n        Returns: Thai summary string\n        \"\"\"\n        if not execution_result.get(\"outputs\"):\n            return f\"[สรุป] ไม่มีผลลัพธ์จากการรันคำสั่งสำหรับ: {original_prompt}\"\n        \n        raw_output = execution_result.get(\"raw\", \"\")\n        if len(raw_output) > 3000:\n            raw_output = raw_output[:3000] + \"...(trimmed)\"\n        \n        summary_prompt = f\"\"\"Summarize the following command execution results in THAI (ภาษาไทย).\nBe very concise — 2-3 sentences maximum.\n\nOriginal request: {original_prompt}\n\nExecution results:\n{raw_output}\n\nThai summary:\"\"\"\n        \n        # ถ้ามี cloud key → ใช้ MiniMax\n        if self.api_key and len(self.api_key) > 10:\n            try:\n                return call_llm(\n                    self.cloud_cfg[\"base_url\"],\n                    self.cloud_cfg[\"model\"],\n                    summary_prompt,\n                    api_key=self.api_key,\n                    system=\"You summarize command outputs in Thai. Be short and clear.\",\n                    timeout=120\n                )\n            except Exception as e:\n                pass  # fallback below\n        \n        # Fallback: ใช้ Local LLM\n        return call_llm(\n            self.local_cfg[\"base_url\"],\n            self.local_cfg[\"model\"],\n            summary_prompt,\n            api_key=self.local_cfg[\"api_key\"],\n            system=\"You summarize in Thai. Be short.\",\n            timeout=90\n        )\n\n\n# ============================================================================\n# SECTION 7: MAIN BRIDGE CLASS (Complete 8/8 Pipeline)\n# ============================================================================","oldText":"# ============================================================================\n# SECTION 6: MAIN BRIDGE CLASS\n# ============================================================================"}],"path":"/home/apinan/.openclaw/workspace/scripts/universal_bridge.py"}}],"api":"openai-completions","provider":"ollama-pay","model":"deepseek-v4-pro:cloud","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1778246946103,"responseId":"chatcmpl-1778246985280"}}
