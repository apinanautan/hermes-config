te.py:158:        self, agent: \"OpenAIOperatorAgent\", context: Optional[\"Context\"] = None\nufo/agents/states/operator_state.py:167:    def next_agent(self, agent: \"OpenAIOperatorAgent\") -> HostAgent:\nufo/agents/states/operator_state.py:175:    def next_state(self, agent: \"OpenAIOperatorAgent\") -> HostAgentState:\nufo/agents/states/operator_state.py:187:            return AllFinishOpenAIOperatorState()\nufo/agents/states/operator_state.py:202:        return OpenAIOperatorStatus.FINISH.value\nufo/agents/states/operator_state.py:205:@OpenAIOperatorStateManager.register\nufo/agents/states/ogrep: ufo/agents/states/__pycache__/host_agent_state.cpython-310.pyc: binary file matches\ngrep: ufo/agents/states/__pycache__/operator_state.cpython-310.pyc: binary file matches\ngrep: ufo/config/__pycache__/__init__.cpython-310.pyc: binary file matches\nperator_state.py:206:class ContinueOpenAIOperatorState(OpenAIOperatorState):\nufo/agents/states/operator_state.py:212:        self, agent: \"OpenAIOperatorAgent\", context: Optional[\"Context\"] = None\nufo/agents/states/operator_state.py:234:        return OpenAIOperatorStatus.CONTINUE.value\nufo/agents/states/operator_state.py:237:@OpenAIOperatorStateManager.register\nufo/agents/states/operator_state.py:238:class PendingOpenAIOperatorState(OpenAIOperatorState):\nufo/agents/states/operator_state.py:244:        self, agent: \"OpenAIOperatorAgent\", context: Optional[\"Context\"] = None\nufo/agents/states/operator_state.py:255:    def next_state(self, agent: OpenAIOperatorAgent) -> OpenAIOperatorState:\nufo/agents/states/operator_state.py:261:        agent.status = OpenAIOperatorStatus.CONTINUE.value\nufo/agents/states/operator_state.py:262:        return ContinueOpenAIOperatorState()\nufo/agents/states/operator_state.py:277:        return OpenAIOperatorStatus.PENDING.value\nufo/agents/states/operator_state.py:280:@OpenAIOperatorStateManager.register\nufo/agents/states/operator_state.py:281:class ConfirmOpenAIOperatorState(OpenAIOperatorState):\nufo/agents/states/operator_state.py:293:        self, agent: \"OpenAIOperatorAgent\", context: Optional[\"Context\"] = None\nufo/agents/states/operator_state.py:313:    def next_state(self, agent: OpenAIOperatorAgent) -> OpenAIOperatorState:\nufo/agents/states/operator_state.py:323:        # The next state should be FinishOpenAIOperatorState.\nufo/agents/states/operator_state.py:324:        if len(plan) > 0 and OpenAIOperatorStatus.FINISH.value in plan[0]:\nufo/agents/states/operator_state.py:325:            agent.status = OpenAIOperatorStatus.FINISH.value\nufo/agents/states/operator_state.py:326:            return FinishOpenAIOperatorState()\nufo/agents/states/operator_state.py:329:            agent.status = OpenAIOperatorStatus.CONTINUE.value\nufo/agents/states/operator_state.py:330:            return ContinueOpenAIOperatorState()\nufo/agents/states/operator_state.py:332:            agent.status = OpenAIOperatorStatus.FINISH.value\nufo/agents/states/operator_state.py:348:        return OpenAIOperatorStatus.CONFIRM.value\nufo/agents/states/operator_state.py:351:@OpenAIOperatorStateManager.register\nufo/agents/states/operator_state.py:352:class ErrorOpenAIOperatorState(OpenAIOperatorState):\nufo/agents/states/operator_state.py:358:        self, agent: \"OpenAIOperatorAgent\", context: Optional[\"Context\"] = None\nufo/agents/states/operator_state.py:368:    def next_agent(self, agent: \"OpenAIOperatorAgent\") -> HostAgent:\nufo/agents/states/operator_state.py:376:    def next_state(self, agent: \"OpenAIOperatorAgent\") -> HostAgentState:\nufo/agents/states/operator_state.py:404:        return OpenAIOperatorStatus.ERROR.value\nufo/agents/states/operator_state.py:407:@OpenAIOperatorStateManager.register\nufo/agents/states/operator_state.py:408:class NoneOpenAIOperatorState(OpenAIOperatorState):\nufo/agents/states/operator_state.py:413:    def next_agent(self, agent: \"OpenAIOperatorAgent\") -> HostAgent:\nufo/agents/states/operator_state.py:421:  