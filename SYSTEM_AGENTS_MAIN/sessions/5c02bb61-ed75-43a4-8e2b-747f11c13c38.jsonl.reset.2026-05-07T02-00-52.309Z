SE:\\s*)\"[^\"]+\"(\\s*#.*)$', r'\\1\"https://api.openai.com/v1\"\\2', s, flags=re.M)\ns=re.sub(r'^(\\s*API_KEY:\\s*)\"[^\"]*\"(\\s*#.*)$', lambda m: f'{m.group(1)}\"{key}\"{m.group(2)}', s, flags=re.M)\ns=re.sub(r'^(\\s*API_MODEL:\\s*)\"[^\"]+\"(\\s*#.*)$', r'\\1\"gpt-4o-mini\"\\2', s, flags=re.M)\ns=re.sub(r'^(MAX_TOKENS:\\s*)\\d+(\\s*#.*)$', r'\\1800\\2', s, flags=re.M)\ns=re.sub(r'^(TIMEOUT:\\s*)\\d+(\\s*#.*)$', r'\\190\\2', s, flags=re.M)\np.write_text(s)\nPY\n# Patch UFO to actually send output token cap; it was commented out upstream.\npython3 - <<'PY'\nfrom pathlib import Path\np=Path('/mnt/c/Users/Apinan/Tools/UFO/ufo/llm/openai.py')\ns=p.read_text()\nold='''                        \"temperature\": temperature,\\n                        # \"max_tokens\": max_tokens,\\n                        \"top_p\": top_p,'''\nnew='''                        \"temperature\": temperature,\\n                        \"max_tokens\": max_tokens,\\n                        \"top_p\": top_p,'''\nif old in s:\n    p.write_text(s.replace(old,new,1))\nPY\n# Set image detail low to reduce vision token usage.\npython3 - <<'PY'\nfrom pathlib import Path\np=Path('/mnt/c/Users/Apinan/Tools/UFO/ufo/agents/memory/blackboard.py')\ns=p.read_text()\nold='''                    \"image_url\": {\\n                        \"url\": screenshot_dict.get(ImageMemoryItemNames.IMAGE_STR, \"\")\\n                    },'''\nnew='''                    \"image_url\": {\\n                        \"url\": screenshot_dict.get(ImageMemoryItemNames.IMAGE_STR, \"\"),\\n                        \"detail\": \"low\",\\n                    },'''\nif old in s:\n    p.write_text(s.replace(old,new,1))\nPY\nprintf 'backup=%s\\n' \"$BACK\"\npython3 - <<'PY'\nfrom pathlib import Path\nimport re\ns=Path('/mnt/c/Users/Apinan/Tools/UFO/config/ufo/agents.yaml').read_text()\nfor key in ['VISUAL_MODE','API_BASE','API_MODEL','MAX_TOKENS','TIMEOUT']:\n    vals=re.findall(rf'^{key}:.*|^\\s+{key}:.*', s, re.M)\n    print(key, vals[:4])\nPY","workdir":"/home/apinan/.openclaw/workspace","yieldMs":10000,"timeout":30}}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.5","usage":{"input":751,"output":1326,"cacheRead":54272,"cacheWrite":0,"totalTokens":56349,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778118914782,"responseId":"resp_0d371f2cfb221f1c0169fbf10315b48191b1473e47cf6576b2"}}
