instance(data[key], dict) and 'sessionFile' in data[key]:\n        print(key)\n\" 2>/dev/null\n}\n\n# Get session file path\nget_session_file() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\nprint(data.get(key, {}).get('sessionFile', ''))\n\" \"$1\" 2>/dev/null\n}\n\n# Get last interaction time\nget_last_interaction() {\n    python3 -c \"\nimport json, sys\nkey = sys.argv[1]\nwith open('$SESSION_JSON', 'r') as f:\n    data = json.load(f)\ninfo = data.get(key, {})\nprint(info.get('lastInteractionAt', 0))\n\" \"$1\" 2>/dev/null\n}\n\n# Compact a single session jsonl\ncompact_session() {\n    local session_key=\"$1\"\n    local session_file=\"$2\"\n    \n    [ ! -f \"$session_file\" ] && return\n    \n    local msg_count\n    msg_count=$(count_messages \"$session_file\")\n    # Remove any trailing whitespace/newlines\n    msg_count=$(echo \"$msg_count\" | tr -d '[:space:]')\n    \n    [ -z \"$msg_count\" ] && msg_count=0\n    \n    if [ \"$msg_count\" -le \"$KEEP_MESSAGES\" ]; then\n        return\n    fi\n    \n    # Backup\n    local backup=\"${session_file}.compact-$(date +%Y%m%d-%H%M%S)\"\n    cp \"$session_file\" \"$backup\"\n    \n    # Parse jsonl, keep header lines + last N messages using heredoc\n    python3 << PYEOF\nimport json, sys, os\n\ninput_file = '$session_file'\nkeep_messages = $KEEP_MESSAGES\n\nmessages = []\nheader = []\n\nwith open(input_file, 'r') as f:\n    for line in f:\n        try:\n            obj = json.loads(line)\n            if obj.get('type') == 'message':\n                messages.append(line)\n            else:\n                header.append(line)\n        except:\n            header.append(line)\n\nwith open(input_file + '.tmp', 'w') as f:\n    for line in header:\n        f.write(line)\n    for line in messages[-keep_messages:]:\n        f.write(line)\n\nprint(f'COMPACT: {len(messages)} -> {min(len(messages), keep_messages)} messages', flush=True)\nPYEOF\n  