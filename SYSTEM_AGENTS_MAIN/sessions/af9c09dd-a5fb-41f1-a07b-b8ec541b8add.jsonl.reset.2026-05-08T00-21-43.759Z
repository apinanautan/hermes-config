{"type":"message","id":"c1da933d","parentId":"ed61be9f","timestamp":"2026-05-07T22:29:00.313Z","message":{"role":"toolResult","toolCallId":"call_cZ58QwZWdwb5ckOcKMKQQlYl|fc_089f5c82f7390fab0169fd122c0d3c8191aa20d243b44bb877","toolName":"ollama__list","content":[{"type":"text","text":"{\n  \"models\": [\n    {\n      \"name\": \"hermes3:8b\",\n      \"model\": \"hermes3:8b\",\n      \"modified_at\": \"2026-05-08T05:24:59.38772816+07:00\",\n      \"size\": 4661227243,\n      \"digest\": \"4f6b83f30b62bc3d0cf9be09266db222805ee815c8fd7d8b38f863f655be78b7\",\n      \"details\": {\n        \"parent_model\": \"\",\n        \"format\": \"gguf\",\n        \"family\": \"llama\",\n        \"families\": [\n          \"llama\"\n        ],\n        \"parameter_size\": \"8.0B\",\n        \"quantization_level\": \"Q4_0\"\n      }\n    },\n    {\n      \"name\": \"qwen2.5:3b\",\n      \"model\": \"qwen2.5:3b\",\n      \"modified_at\": \"2026-05-07T18:00:02.19225452+07:00\",\n      \"size\": 1929912432,\n      \"digest\": \"357c53fb659c5076de1d65ccb0b397446227b71a42be9d1603d46168015c9e4b\",\n      \"details\": {\n        \"parent_model\": \"\",\n        \"format\": \"gguf\",\n        \"family\": \"qwen2\",\n        \"families\": [\n          \"qwen2\"\n        ],\n        \"parameter_size\": \"3.1B\",\n        \"quantization_level\": \"Q4_K_M\"\n      }\n    },\n    {\n      \"name\": \"moondream:latest\",\n      \"model\": \"moondream:latest\",\n      \"modified_at\": \"2026-05-07T16:25:51.479341612+07:00\",\n      \"size\": 1738451197,\n      \"digest\": \"55fc3abd386771e5b5d1bbcc732f3c3f4df6e9f9f08f1131f9cc27ba2d1eec5b\",\n      \"details\": {\n        \"parent_model\": \"\",\n        \"format\": \"gguf\",\n        \"family\": \"phi2\",\n        \"families\": [\n          \"phi2\",\n          \"clip\"\n        ],\n        \"parameter_size\": \"1B\",\n        \"quantization_level\": \"Q4_0\"\n      }\n    },\n    {\n      \"name\": \"nomic-embed-text:latest\",\n      \"model\": \"n