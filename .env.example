# Hermes Node Environment — Example
# Copy to .env and fill in your local values
# WARNING: Never commit .env to git!

# === Node Identity ===
HERMES_NODE_NAME=Hermes-PC
HERMES_GIT_MODE=writer

# === API Keys (use your own — never commit real keys) ===
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OLLAMA_PAY_API_KEY=your-ollama-pay-key-here

# === Paths ===
# PC (Windows): HERMES_HOME=C:\Users\Apinan\AppData\Local\hermes
# Mac: HERMES_HOME=~/hermes-config

# === Browser Automation (Windows only) ===
CLOAKBROWSER_PROFILE=C:\Users\Apinan\AppData\Local\CloakBrowser\data
ADSPOWER_PROFILE_ID=k1cawerp

# === Consultation ===
OWENGPT_URL=https://chatgpt.com/g/g-6a0092c4d6048191a3e494dd47f18616
