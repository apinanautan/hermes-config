# Minimal ignores for full system visibility in OwenGPT
node_modules/
logs/
.DS_Store
*.tmp
*.bak*
*.session
*.token
temp/
.openclaw/bin/
.openclaw/cache/
.openclaw/node/

# Recovery / sandbox
docs/consultation/
sandbox/

# Session summaries
SYSTEM_AGENTS_MAIN/sessions/.summaries/

# Quarantine
.cleanup-quarantine/

# Disabled scripts
*.disabled
.env
.env.local
.env.*.local

# Python cache
__pycache__/
*.pyc

# Runtime state (contains offsets/ports)
scripts/.dispatcher_offset.json
scripts/.owengpt_port